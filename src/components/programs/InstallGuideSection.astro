---
import { Icon } from 'astro-icon/components';
// /programs 페이지 — 다운로드 섹션과 "추가 프로그램" 사이의 "설치 방법" 섹션.
// OS 탭(Windows/Linux/macOS) + 단계별 타임라인.
//
// 데이터 구조:
//   panels: OS별 설치 가이드. status='ready' 면 steps 노출, 'soon' 이면 placeholder.
//   각 step 은 변형(variant)을 가질 수 있으며 GUI/터미널 같은 방법 분기를 표현.
//
// 새 OS 빌드가 준비되면 해당 panel 의 status 를 'ready' 로 바꾸고 steps 채우기.

interface Step {
  num: string;
  title: string;
  body?: string;
  code?: string;
  variant?: 'gui' | 'terminal';
}

interface Tip {
  title: string;
  text: string;
  href?: string;
  hrefLabel?: string;
}

interface OSPanel {
  key: 'windows' | 'linux' | 'mac';
  label: string;
  iconName: string;
  status: 'ready' | 'soon';
  steps: Step[];
  tip?: Tip;
}

// 기본은 모든 패널 닫힘 — 사용자가 탭을 누르면 펼쳐지고, 같은 탭을 다시 누르면 닫힘.
const panels: OSPanel[] = [
  {
    key: 'windows',
    label: 'Windows',
    iconName: 'fa6-brands:windows',
    status: 'soon',
    steps: [],
  },
  {
    key: 'linux',
    label: 'Linux',
    iconName: 'fa6-brands:linux',
    status: 'ready',
    steps: [
      {
        num: '1',
        title: '.deb 파일 다운로드',
        body:
          '위 Download RoboSEasy Studio 섹션의 [.deb] 버튼을 클릭하세요. ' +
          'roboseasy-studio_<버전>_amd64.deb 파일이 다운로드됩니다.',
      },
      {
        num: '2',
        title: '설치 — 터미널',
        variant: 'terminal',
        body:
          '터미널을 열고 다운로드 폴더로 이동한 뒤 아래 명령을 실행합니다. ' +
          'apt 가 의존 패키지를 자동으로 함께 설치해 줍니다.',
        code: 'cd ~/Downloads\nsudo apt install ./roboseasy-studio_*.deb',
      },
      {
        num: '3',
        title: '앱 실행',
        body:
          '키보드의 Super(⊞) 키를 눌러 액티비티에서 "Roboseasy" 를 검색하거나, ' +
          '앱 그리드에서 Roboseasy 아이콘을 클릭하세요.',
      },
    ],
    tip: {
      title: 'USB 모터·카메라 권한',
      text:
        'STS3215 모터나 카메라를 USB 로 연결하려면 사용자가 dialout 그룹에 속해야 합니다. ' +
        '자세한 내용은 문서의 시리얼 포트 권한 가이드를 참고하세요.',
      href: '/docs',
      hrefLabel: '문서 보기',
    },
  },
  {
    key: 'mac',
    label: 'macOS',
    iconName: 'fa6-brands:apple',
    status: 'soon',
    steps: [],
  },
];

---
<section class="install-guide" id="install-guide">
  <div class="install-guide__header">
    <div class="install-guide__decorators" aria-hidden="true">
      <span class="install-guide__decorator"></span>
      <span class="install-guide__decorator"></span>
      <span class="install-guide__decorator"></span>
    </div>
    <h2 class="install-guide__heading">설치 방법</h2>
    <p class="install-guide__description">
      다운로드한 파일을 운영체제에 맞춰 설치하세요
    </p>
  </div>

  <div class="install-guide__tabs" role="tablist" aria-label="운영체제 선택">
    {panels.map((p) => (
      <button
        type="button"
        role="tab"
        class="install-guide__tab"
        data-tab={p.key}
        aria-selected="false"
        aria-expanded="false"
        aria-controls={`install-panel-${p.key}`}
        id={`install-tab-${p.key}`}
      >
        <Icon name={p.iconName} aria-hidden="true" />
        <span class="install-guide__tab-label">{p.label}</span>
        {p.status === 'soon' && (
          <span class="install-guide__tab-badge">준비 중</span>
        )}
      </button>
    ))}
  </div>

  <div class="install-guide__panels">
    {panels.map((p) => (
      <div
        role="tabpanel"
        id={`install-panel-${p.key}`}
        aria-labelledby={`install-tab-${p.key}`}
        class={`install-guide__panel install-guide__panel--${p.status}`}
        data-panel={p.key}
        hidden
      >
        <div class="install-guide__panel-inner">
        {p.status === 'soon' ? (
          <div class="install-guide__soon">
            <Icon name="fa6-regular:clock" class="install-guide__soon-icon" aria-hidden="true" />
            <p class="install-guide__soon-title">{p.label} 빌드 준비 중입니다</p>
            <p class="install-guide__soon-text">
              정식 빌드가 출시되면 이곳에 설치 방법을 안내해 드릴게요.
            </p>
          </div>
        ) : (
          <>
            <ol class="install-guide__timeline">
              {p.steps.map((s) => (
                <li class={`install-guide__step${s.variant ? ' install-guide__step--' + s.variant : ''}`}>
                  <span class="install-guide__step-num" aria-hidden="true">{s.num}</span>
                  <div class="install-guide__step-body">
                    <h3 class="install-guide__step-title">
                      {s.variant === 'gui' && (
                        <Icon name="fa6-solid:arrow-pointer" class="install-guide__step-title-icon" aria-hidden="true" />
                      )}
                      {s.variant === 'terminal' && (
                        <Icon name="fa6-solid:terminal" class="install-guide__step-title-icon" aria-hidden="true" />
                      )}
                      {s.title}
                    </h3>
                    {s.body && <p class="install-guide__step-text">{s.body}</p>}
                    {s.code && (
                      <div class="install-guide__code">
                        <button
                          type="button"
                          class="install-guide__copy-btn"
                          data-copy-target={`code-${p.key}-${s.num}`}
                          aria-label="명령어 복사"
                        >
                          <Icon name="fa6-regular:copy" aria-hidden="true" />
                          <span class="install-guide__copy-label">복사</span>
                        </button>
                        <pre><code id={`code-${p.key}-${s.num}`}>{s.code}</code></pre>
                      </div>
                    )}
                  </div>
                </li>
              ))}
            </ol>

            {p.tip && (
              <aside class="install-guide__tip" role="note">
                <Icon name="fa6-solid:circle-info" class="install-guide__tip-icon" aria-hidden="true" />
                <div class="install-guide__tip-body">
                  <p class="install-guide__tip-title">{p.tip.title}</p>
                  <p class="install-guide__tip-text">
                    {p.tip.text}
                    {p.tip.href && (
                      <>
                        {' '}
                        <a class="install-guide__tip-link" href={p.tip.href}>
                          {p.tip.hrefLabel ?? '자세히'}
                          <Icon name="fa6-solid:arrow-right" aria-hidden="true" />
                        </a>
                      </>
                    )}
                  </p>
                </div>
              </aside>
            )}
          </>
        )}
        </div>
      </div>
    ))}
  </div>

  <div class="install-guide__toast" id="install-guide-toast" role="status" aria-live="polite" aria-atomic="true"></div>
</section>

<script>
  // 탭 전환 + 코드 복사 버튼.
  // tabs 와 panels 를 data-tab / data-panel 매칭으로 토글, hidden 속성과 active modifier 동기화.
  (() => {
    const root = document.querySelector<HTMLElement>('.install-guide');
    if (!root) return;

    const tabs = root.querySelectorAll<HTMLButtonElement>('.install-guide__tab');
    const panels = root.querySelectorAll<HTMLElement>('.install-guide__panel');

    // 토글 모드: 클릭한 탭이 이미 열려있으면 모두 닫고, 아니면 그 탭만 열기.
    // 패널은 기본 hidden 이며, 펼침 애니메이션은 grid-template-rows 0fr→1fr 트랜지션.
    const TRANSITION_MS = 320; // CSS transition 길이와 동기화
    const hideTimers = new WeakMap<HTMLElement, number>();

    const setOpen = (key: string | null) => {
      tabs.forEach((tab) => {
        const active = tab.dataset.tab === key;
        tab.classList.toggle('install-guide__tab--active', active);
        tab.setAttribute('aria-selected', active ? 'true' : 'false');
        tab.setAttribute('aria-expanded', active ? 'true' : 'false');
      });
      panels.forEach((panel) => {
        const active = panel.dataset.panel === key;
        const prevTimer = hideTimers.get(panel);
        if (prevTimer) {
          window.clearTimeout(prevTimer);
          hideTimers.delete(panel);
        }
        if (active) {
          // hidden 을 먼저 제거해야 다음 프레임에서 트랜지션이 동작
          panel.removeAttribute('hidden');
          requestAnimationFrame(() => {
            panel.classList.add('install-guide__panel--open');
          });
        } else {
          panel.classList.remove('install-guide__panel--open');
          // 닫힘 트랜지션 종료 후 hidden 재부여 — 스크린리더 일관성
          const timer = window.setTimeout(() => {
            if (!panel.classList.contains('install-guide__panel--open')) {
              panel.setAttribute('hidden', '');
            }
            hideTimers.delete(panel);
          }, TRANSITION_MS);
          hideTimers.set(panel, timer);
        }
      });
    };

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const key = tab.dataset.tab;
        if (!key) return;
        const isOpen = tab.classList.contains('install-guide__tab--active');
        setOpen(isOpen ? null : key);
      });
    });

    // 복사 버튼
    const toast = document.getElementById('install-guide-toast');
    let toastTimer: number | undefined;
    const showToast = (msg: string) => {
      if (!toast) return;
      toast.textContent = msg;
      toast.classList.add('install-guide__toast--visible');
      if (toastTimer) window.clearTimeout(toastTimer);
      toastTimer = window.setTimeout(() => {
        toast.classList.remove('install-guide__toast--visible');
      }, 1500);
    };

    root.querySelectorAll<HTMLButtonElement>('.install-guide__copy-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const targetId = btn.dataset.copyTarget;
        if (!targetId) return;
        const target = document.getElementById(targetId);
        if (!target) return;
        const text = target.textContent ?? '';
        try {
          await navigator.clipboard.writeText(text);
          showToast('복사되었습니다');
        } catch {
          showToast('복사에 실패했어요');
        }
      });
    });
  })();
</script>
