---
// Shop sub-site header: Shop · Products ——— Logo ——— (spacer)
---
<header class="header">
  <div class="header__container shop-header__container">
    <!-- Left: nav links -->
    <nav class="shop-header__nav-left">
      <a href="/shop" class="header__nav-link shop-header__link" data-path="/shop">Shop</a>
      <a href="/products" class="header__nav-link shop-header__link" data-path="/products">Products</a>
    </nav>

    <!-- Center: logo -->
    <a href="/" class="shop-header__logo">
      <img src="/img/logo.png" alt="RoboSEasy Logo" class="header__logo-image" />
    </a>

    <!-- Right: spacer (desktop) / hamburger (mobile) -->
    <div class="shop-header__spacer">
      <button class="header__menu-toggle shop-header__menu-toggle" aria-label="메뉴 열기">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <!-- Mobile dropdown nav -->
  <div class="shop-header__overlay"></div>
  <nav class="shop-header__mobile-nav" aria-hidden="true">
    <a href="/shop" class="header__nav-link shop-header__mobile-link" data-path="/shop">Shop</a>
    <a href="/products" class="header__nav-link shop-header__mobile-link" data-path="/products">Products</a>
  </nav>
</header>

<style is:global>
  .shop-header__container {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
  }

  .shop-header__nav-left {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .shop-header__link.is-active {
    color: var(--color-signal-violet);
    font-weight: var(--fw-bold);
  }

  .shop-header__logo {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }

  .shop-header__spacer {
    display: flex;
    justify-content: flex-end;
    align-items: center;
  }

  /* Hide hamburger on desktop */
  .shop-header__menu-toggle {
    display: none;
  }

  /* Mobile nav — hidden by default */
  .shop-header__mobile-nav {
    display: none;
    flex-direction: column;
    position: fixed;
    top: 64px;
    left: 0;
    width: 100%;
    background-color: var(--color-pure-white);
    border-bottom: 1px solid var(--color-ash-border);
    padding: 8px 24px 12px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    transform: translateY(-10px);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.22s ease, opacity 0.22s ease;
    z-index: 999;
  }

  .shop-header__mobile-nav.is-open {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .shop-header__mobile-link {
    display: block;
    padding: 14px 4px;
    border-bottom: 1px solid var(--color-ash-border);
    color: var(--color-ink);
    border-radius: 0;
    font-weight: var(--fw-medium);
  }

  .shop-header__mobile-link:last-child {
    border-bottom: none;
  }

  .shop-header__mobile-link.is-active {
    color: var(--color-signal-violet);
    font-weight: var(--fw-bold);
  }

  .shop-header__overlay {
    display: none;
    position: fixed;
    top: 64px;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(15, 23, 42, 0.15);
    z-index: 998;
  }

  .shop-header__overlay.is-visible {
    display: block;
  }

  @media screen and (max-width: 768px) {
    .shop-header__nav-left {
      display: none;
    }

    .shop-header__mobile-nav {
      display: flex;
    }

    .shop-header__menu-toggle {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 5px;
      width: 40px;
      height: 40px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 5px;
    }
  }
</style>

<script>
  // Active link detection
  const path = window.location.pathname;
  document.querySelectorAll('.shop-header__link, .shop-header__mobile-link').forEach((link) => {
    const linkPath = (link as HTMLElement).dataset.path ?? '';
    if (linkPath && path.startsWith(linkPath)) {
      link.classList.add('is-active');
    }
  });

  // Hamburger toggle
  const menuToggle = document.querySelector('.shop-header__menu-toggle');
  const mobileNav  = document.querySelector('.shop-header__mobile-nav');
  const overlay    = document.querySelector('.shop-header__overlay');

  const closeMenu = () => {
    menuToggle?.classList.remove('is-active');
    mobileNav?.classList.remove('is-open');
    mobileNav?.setAttribute('aria-hidden', 'true');
    overlay?.classList.remove('is-visible');
    document.body.style.overflow = '';
  };

  if (menuToggle && mobileNav && overlay) {
    menuToggle.addEventListener('click', () => {
      const isOpen = mobileNav.classList.toggle('is-open');
      menuToggle.classList.toggle('is-active');
      overlay.classList.toggle('is-visible');
      mobileNav.setAttribute('aria-hidden', String(!isOpen));
      document.body.style.overflow = isOpen ? 'hidden' : '';
    });

    overlay.addEventListener('click', closeMenu);

    mobileNav.querySelectorAll('.shop-header__mobile-link').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });
  }
</script>
