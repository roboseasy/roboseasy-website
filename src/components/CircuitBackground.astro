---
// 히어로 섹션 PCB 회로 애니메이션 배경
---
<canvas class="circuit-bg" id="hero-circuit" aria-hidden="true"></canvas>

<style>
  .circuit-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    pointer-events: none;
    z-index: 1;
  }
</style>

<script>
(function () {
  const canvas = document.getElementById('hero-circuit');
  if (!(canvas instanceof HTMLCanvasElement)) return;

  const COLORS = ['#8a5cf5', '#049ED8', '#1e6fba'];

  class Circuit {
    constructor(el) {
      this.el = el;
      this.ctx = el.getContext('2d');
      this.active = [];
      this.MAX_LIGHTS = 1;        // 한 번에 하나의 빛만 표시
      this.REVEAL_RADIUS = 130;   // 빛 주위 회로 노출 반경 (확장)
      this.JUMP_PAUSE = 0.22;     // 중간 끊김에서 점프 대기(초)
      this.last = 0;

      this._resize();
      this._build();
      this._loop(0);

      let raf;
      window.addEventListener('resize', () => {
        clearTimeout(raf);
        raf = setTimeout(() => { this._resize(); this._build(); }, 120);
      }, { passive: true });
    }

    _resize() {
      const dpr = window.devicePixelRatio || 1;
      const parent = this.el.parentElement;
      this.W = parent.clientWidth;
      this.H = parent.clientHeight || window.innerHeight - 85;

      this.el.style.height = this.H + 'px';
      this.el.width  = Math.round(this.W * dpr);
      this.el.height = Math.round(this.H * dpr);
      this.ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    _q(xp, yp) { return { x: xp / 100 * this.W, y: yp / 100 * this.H }; }

    /* ── 경로 정의 ──
     * 좌 5개 시작선(L1~L5) — index 0~6
     * 우 4개 시작선(R1~R4) — index 7~12
     * 각 시작선은 최대 2갈래까지 분기. 좌측 끝점과 우측 시작점 사이는
     * 중간 회로가 끊긴 영역(점프 구간).
     */
    _build() {
      const q = (x, y) => this._q(x, y);

      // 13개 경로 모두 고유한 가로 길이 (23~36% 범위)
      // 중간 영역(36~64%)은 여전히 비어있음
      this.paths = [
        // ===== LEFT: 5 starting lines =====
        /* 0 */ { pts: [q(0, 4),  q(15, 4),  q(22, 8),  q(35, 8)] },   // L1m  len 35
        /* 1 */ { pts: [q(0, 4),  q(15, 4),  q(22, 2),  q(33, 2)] },   // L1b  len 33
        /* 2 */ { pts: [q(0, 12), q(28, 12)] },                         // L2   len 28
        /* 3 */ { pts: [q(0, 18), q(12, 18), q(18, 15), q(32, 15)] },  // L3m  len 32
        /* 4 */ { pts: [q(0, 18), q(12, 18), q(18, 21), q(30, 21)] },  // L3b  len 30
        /* 5 */ { pts: [q(0, 25), q(24, 25)] },                         // L4   len 24
        /* 6 */ { pts: [q(0, 29), q(13, 29), q(18, 27), q(26, 27)] },  // L5   len 26

        // ===== RIGHT: 4 starting lines =====
        /* 7 */ { pts: [q(100, 6),  q(85, 6),  q(78, 10), q(64, 10)] },// R1m  len 36
        /* 8 */ { pts: [q(100, 6),  q(85, 6),  q(78, 3),  q(66, 3)] }, // R1b  len 34
        /* 9 */ { pts: [q(100, 14), q(73, 14)] },                      // R2   len 27
        /*10 */ { pts: [q(100, 20), q(88, 20), q(82, 17), q(69, 17)] },// R3m  len 31
        /*11 */ { pts: [q(100, 20), q(88, 20), q(82, 23), q(71, 23)] },// R3b  len 29
        /*12 */ { pts: [q(100, 28), q(77, 28)] },                      // R4   len 23
      ];

      // 각 경로 inner 끝점 = 원형 노드 위치
      this.endpoints = this.paths.map(p => p.pts[p.pts.length - 1]);

      // 좌측 / 우측 경로 인덱스 분리
      this.leftIdx  = [0, 1, 2, 3, 4, 5, 6];
      this.rightIdx = [7, 8, 9, 10, 11, 12];

      // 세그먼트 목록 (분기 trunk 중복 제거)
      const seen = new Set();
      this.segs = [];
      for (const p of this.paths) {
        for (let i = 0; i < p.pts.length - 1; i++) {
          const a = p.pts[i], b = p.pts[i + 1];
          const key = `${a.x.toFixed(1)},${a.y.toFixed(1)},${b.x.toFixed(1)},${b.y.toFixed(1)}`;
          if (!seen.has(key)) { seen.add(key); this.segs.push([a, b]); }
        }
      }
    }

    _len(pts) {
      let l = 0;
      for (let i = 0; i < pts.length - 1; i++) {
        const dx = pts[i+1].x - pts[i].x, dy = pts[i+1].y - pts[i].y;
        l += Math.sqrt(dx*dx + dy*dy);
      }
      return l;
    }

    _at(pts, dist) {
      let acc = 0;
      for (let i = 0; i < pts.length - 1; i++) {
        const dx = pts[i+1].x - pts[i].x, dy = pts[i+1].y - pts[i].y;
        const sl = Math.sqrt(dx*dx + dy*dy);
        if (acc + sl >= dist - 0.001) {
          const u = sl > 0 ? Math.min((dist - acc) / sl, 1) : 0;
          return { x: pts[i].x + dx * u, y: pts[i].y + dy * u };
        }
        acc += sl;
      }
      return pts[pts.length - 1];
    }

    /* ── 빛 1개 생성 ──
     * 항상 좌→우 방향. 좌측 경로 랜덤 선택 → 끊긴 구간에서 점프 →
     * 우측 경로 랜덤 선택 (역순으로 진행하여 우측 끝까지).
     */
    _spawn() {
      if (this.active.length >= this.MAX_LIGHTS) return;

      const li = this.leftIdx[Math.floor(Math.random() * this.leftIdx.length)];
      const ri = this.rightIdx[Math.floor(Math.random() * this.rightIdx.length)];

      const p1 = this.paths[li].pts.slice();             // 좌 edge → 안쪽 끝
      const p2 = [...this.paths[ri].pts].reverse();      // 안쪽 끝 → 우 edge

      const color = COLORS[Math.floor(Math.random() * COLORS.length)];
      const speed = 150 + Math.random() * 50;

      this.active.push({
        pts: p1,
        len: this._len(p1),
        d: 0,
        speed,
        color,
        next: { pts: p2, len: this._len(p2) },
        gap: 0,                  // >0 이면 점프 대기 중 (렌더 안 함)
      });
    }

    _loop(t) {
      const dt = this.last ? Math.min((t - this.last) / 1000, 0.05) : 0;
      this.last = t;

      for (const a of this.active) {
        if (a.gap > 0) {
          a.gap -= dt;
          if (a.gap <= 0) {
            a.gap = 0;
            a.pts = a.next.pts;
            a.len = a.next.len;
            a.d   = 0;
            a.next = null;
          }
          continue;
        }
        a.d += a.speed * dt;
        if (a.d >= a.len) {
          if (a.next) a.gap = this.JUMP_PAUSE;
          else a.done = true;
        }
      }
      this.active = this.active.filter(a => !a.done);

      // 한 빛이 끝나면 즉시 새 빛 시작 (전체 깜빡임 방지)
      if (this.active.length === 0) this._spawn();

      const ctx = this.ctx;
      ctx.clearRect(0, 0, this.W, this.H);

      this._drawBaseRevealed();
      for (const a of this.active) {
        if (a.gap > 0) continue;   // 점프 대기 중에는 안 그림
        this._drawLight(a);
      }

      requestAnimationFrame(t => this._loop(t));
    }

    /* ── 회로 선: 기본은 보이지 않고, 활성 빛 주변만 드러남 ── */
    _drawBaseRevealed() {
      const visible = this.active.filter(a => a.gap <= 0);
      if (visible.length === 0) return;

      const ctx = this.ctx;
      const R = this.REVEAL_RADIUS;

      ctx.save();
      ctx.strokeStyle = 'rgba(180,200,230,0.55)';
      ctx.lineWidth = 1.1;
      ctx.lineCap = 'round';
      for (const [a, b] of this.segs) {
        ctx.beginPath();
        ctx.moveTo(a.x, a.y);
        ctx.lineTo(b.x, b.y);
        ctx.stroke();
      }

      // 좌·우 회로 끝의 원형 노드
      ctx.fillStyle   = 'rgba(180,200,230,0.18)';
      ctx.strokeStyle = 'rgba(200,215,240,0.85)';
      ctx.lineWidth   = 1.3;
      for (const ep of this.endpoints) {
        ctx.beginPath();
        ctx.arc(ep.x, ep.y, 4.5, 0, Math.PI * 2);
        ctx.fill();
        ctx.stroke();
      }
      ctx.restore();

      ctx.save();
      ctx.globalCompositeOperation = 'destination-in';
      for (const a of visible) {
        const head = this._at(a.pts, a.d);
        const grad = ctx.createRadialGradient(head.x, head.y, 0, head.x, head.y, R);
        grad.addColorStop(0,   'rgba(255,255,255,1)');
        grad.addColorStop(0.5, 'rgba(255,255,255,0.7)');
        grad.addColorStop(1,   'rgba(255,255,255,0)');
        ctx.fillStyle = grad;
        ctx.fillRect(head.x - R, head.y - R, R * 2, R * 2);
      }
      ctx.restore();
    }

    /* ── 빛: 꼬리 없이 헤드만 렌더 ── */
    _drawLight(anim) {
      const ctx = this.ctx;
      const { d, pts, color } = anim;
      const head = this._at(pts, d);

      ctx.save();

      ctx.shadowBlur = 26;
      ctx.shadowColor = color;
      ctx.fillStyle = this._rgba(color, 0.30);
      ctx.beginPath();
      ctx.arc(head.x, head.y, 6, 0, Math.PI * 2);
      ctx.fill();

      ctx.shadowBlur = 14;
      ctx.fillStyle = color;
      ctx.beginPath();
      ctx.arc(head.x, head.y, 2.5, 0, Math.PI * 2);
      ctx.fill();

      ctx.shadowBlur = 0;
      ctx.fillStyle = '#ffffff';
      ctx.beginPath();
      ctx.arc(head.x, head.y, 1.1, 0, Math.PI * 2);
      ctx.fill();

      ctx.restore();
    }

    _rgba(hex, a) {
      const n = parseInt(hex.replace('#', ''), 16);
      return `rgba(${(n>>16)&255},${(n>>8)&255},${n&255},${a.toFixed(3)})`;
    }
  }

  requestAnimationFrame(() => new Circuit(canvas));
})();
</script>
