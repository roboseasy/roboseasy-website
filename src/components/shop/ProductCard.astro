---
// PRODUCTS 1×5 그리드용 작은 제품 카드 — 상품명만(가격 미표시).
// 정사각 이미지 + 하단 제품명. 클릭 시 /products/[id] 상세로 이동.
import type { Product } from '../../data/products';
import BrandPlaceholder from './BrandPlaceholder.astro';

type Props = Product;
const { id, name, category, image } = Astro.props;
---
<a class="product-card" href={`/products/${id}`} data-category={category}>
  <div class="product-card__media">
    {image ? (
      <img class="product-card__image" src={image} alt={name} loading="lazy" />
    ) : (
      <BrandPlaceholder />
    )}
  </div>
  <h3 class="product-card__name">{name}</h3>
</a>

<style>
  .product-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .product-card__media {
    position: relative;
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-cards);
    overflow: hidden;
    background-color: var(--color-surface);
    box-shadow: var(--shadow-subtle-3);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .product-card:hover .product-card__media {
    transform: translateY(-6px);
    box-shadow: var(--shadow-xl);
  }

  .product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .product-card:hover .product-card__image {
    transform: scale(1.05);
  }

  .product-card__name {
    margin: 12px 4px 0;
    font-size: var(--text-body);
    font-weight: var(--fw-semibold);
    line-height: 1.4;
    color: var(--color-bright-gray);
  }
</style>
