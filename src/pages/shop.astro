---
import BaseLayout from '../layouts/BaseLayout.astro';
import ShopHeader from '../components/shop/ShopHeader.astro';
import ProductCard from '../components/shop/ProductCard.astro';
import BrandPlaceholder from '../components/shop/BrandPlaceholder.astro';
import { products } from '../data/products';
import '../styles/pages/shop.css';

const title = 'Shop - RoboSEasy | 로보시지';
const description = 'RoboSEasy 로봇 제품을 만나보세요. SO-ARM101, LeKiwi 등 Physical AI 입문 로봇 플랫폼.';

const heroProducts = products.filter((p) => p.hero);
const featuredProducts = products.filter((p) => p.featured).slice(0, 4);

const promos = [
  { icon: 'ph:truck-bold', text: '빠른 배송' },
  { icon: 'ph:cube-bold', text: '뱀부랩 정품 PLA 사용' },
  { icon: 'ph:envelope-simple-bold', text: 'roboseasy@gmail.com' },
  { icon: 'ph:seal-check-bold', text: 'KC인증' },
];
---
<BaseLayout title={title} description={description} path="/shop" lockTheme="light">
  <ShopHeader />

  <!-- 히어로: 대표 상품 슬라이드 (이미지 풀필 + 오버레이) + 하단 홍보 바 -->
  <section class="shop-hero">
    <div class="shop-hero__slider">
      {heroProducts.map((p, i) => (
        <div class={`shop-hero__slide${i === 0 ? ' is-active' : ''}`} data-index={i}>
          {p.image ? (
            <img class="shop-hero__image" src={p.image} alt={p.name} />
          ) : (
            <BrandPlaceholder />
          )}
          <div class="shop-hero__overlay">
            <h1 class="shop-hero__name">{p.name}</h1>
            <p class="shop-hero__price">{p.price.toLocaleString('ko-KR')}원</p>
            <a class="shop-hero__buy" href="/products">제품 보기</a>
          </div>
        </div>
      ))}

      {heroProducts.length > 1 && (
        <>
          <button class="shop-hero__nav shop-hero__nav--prev" aria-label="이전 상품">
            <iconify-icon icon="solar:alt-arrow-left-bold"></iconify-icon>
          </button>
          <button class="shop-hero__nav shop-hero__nav--next" aria-label="다음 상품">
            <iconify-icon icon="solar:alt-arrow-right-bold"></iconify-icon>
          </button>
        </>
      )}
    </div>

    <!-- 홍보 바 — 히어로 화면 하단 -->
    <div class="shop-promos">
      <div class="shop-promos__container">
        {promos.map((promo) => (
          <div class="shop-promo">
            <iconify-icon class="shop-promo__icon" icon={promo.icon}></iconify-icon>
            <span class="shop-promo__title">{promo.text}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 주요 제품 섹션 -->
  <section class="shop-featured">
    <div class="shop-featured__container">
      <div class="shop-featured__header">
        <h2 class="shop-featured__heading">주요 제품</h2>
      </div>

      <div class="shop-featured__grid">
        {featuredProducts.map((p) => <ProductCard {...p} />)}
      </div>

      <!-- 곧 출시 — 스포트라이트 쇼케이스 -->
      <a class="shop-coming" href="/products">
        <div class="shop-coming__stage">
          <div class="shop-coming__spotlight"></div>
          <div class="shop-coming__product">
            <BrandPlaceholder />
          </div>
          <div class="shop-coming__pedestal"></div>
        </div>
        <span class="shop-coming__eyebrow">NEXT PRODUCT</span>
        <span class="shop-coming__label">COMING SOON</span>
        <span class="shop-coming__sub">곧 공개됩니다. 기대해 주세요.</span>
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  // 히어로 상품 슬라이더 — index.astro news 슬라이더 패턴 재사용
  const slides = document.querySelectorAll<HTMLElement>('.shop-hero__slide');
  if (slides.length > 1) {
    let current = 0;
    const goTo = (idx: number) => {
      slides[current].classList.remove('is-active');
      current = (idx + slides.length) % slides.length;
      slides[current].classList.add('is-active');
    };
    document.querySelector('.shop-hero__nav--prev')?.addEventListener('click', () => goTo(current - 1));
    document.querySelector('.shop-hero__nav--next')?.addEventListener('click', () => goTo(current + 1));
  }
</script>
