---
import BaseLayout from '../layouts/BaseLayout.astro';
import MainBanner from '../components/MainBanner.astro';
import '../styles/pages/home.css';

const title = 'RoboSEasy | 로보시지 - Robot is Easy, 이게 로보시지';
const description = '로봇이 더 쉽고, 더 가까워지도록. 우리는 제품·교육·기술을 통해 전국민의 Physical AI 접근성 향상에 기여합니다';
---
<BaseLayout title={title} description={description} path="/">
  <MainBanner />

  <section class="mobile-hackathon-section">
    <a href="/hackathon" class="mobile-hackathon-button">해커톤 신청하기</a>
    <a href="https://smartstore.naver.com/roboseasy" target="_blank" rel="noopener" class="mobile-shop-button">로봇 구매하기</a>
  </section>

  <section class="content-section">
    <div class="content-section__container">
      <div class="content-section__decorators">
        <span class="content-section__decorator"></span>
        <span class="content-section__decorator"></span>
        <span class="content-section__decorator"></span>
      </div>
      <h2 class="content-section__heading">Trusted By</h2>
      <div class="trusted-by">
        <div class="trusted-by__item">
          <img class="trusted-by__logo" src="/img/opengraph.png" alt="OpenGraph" />
        </div>
        <div class="trusted-by__item">
          <img class="trusted-by__logo" src="/img/hyundai.png" alt="현대자동차" />
        </div>
        <div class="trusted-by__item">
          <img class="trusted-by__logo" src="/img/hansung.png" alt="한성대학교" />
        </div>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="content-section__container">
      <div class="company-tabs">

        <!-- 우: 탭별 교체 패널 -->
        <div class="company-tabs__panels">

          <div class="company-tabs__panel is-active" data-panel="about">
            <div class="about-us about-us--panel">
              <div class="about-us__item about-us__item--accessibility">
                <h3 class="about-us__title">Hardware</h3>
                <p class="about-us__description">TheRobotStudio 공식 파트너<br />SO-ARM 대한민국 공식 판매처</p>
              </div>
              <div class="about-us__item about-us__item--innovation">
                <h3 class="about-us__title">Software</h3>
                <p class="about-us__description">RoboSEasy-Studio 배포<br />CLI가 아닌 UI 데스크탑 앱</p>
              </div>
              <div class="about-us__item about-us__item--sovereignty">
                <h3 class="about-us__title">Education</h3>
                <p class="about-us__description">피지컬 AI 커뮤니티 운영 (1,000명+)<br />해커톤 개최 · 한국어 Documents</p>
              </div>
            </div>
          </div>

          <div class="company-tabs__panel" data-panel="what">
            <div class="what-we-do-panel">
              <div class="what-we-do-panel__item">
                <span class="what-we-do-panel__num">01</span>
                <div>
                  <h4 class="what-we-do-panel__title">모두를 위한 로봇</h4>
                  <p class="what-we-do-panel__desc">학생·메이커도 손에 쥘 수 있는 초저가 Physical AI 플랫폼. SO-ARM 한글 매뉴얼 및 기술 지원 포함.</p>
                </div>
              </div>
              <div class="what-we-do-panel__item">
                <span class="what-we-do-panel__num">02</span>
                <div>
                  <h4 class="what-we-do-panel__title">모두를 위한 AI</h4>
                  <p class="what-we-do-panel__desc">글로벌 최신 기술을 한국어로 정리한 플랫폼. 기업·학교·기관 대상 오프라인 교육 제공.</p>
                </div>
              </div>
              <div class="what-we-do-panel__item">
                <span class="what-we-do-panel__num">03</span>
                <div>
                  <h4 class="what-we-do-panel__title">모두를 위한 가이드</h4>
                  <p class="what-we-do-panel__desc">터미널 없이 UI 앱과 한국어 Documents로 시작하는 Physical AI. 도입 컨설팅 및 개발 지원.</p>
                </div>
              </div>
              <div class="what-we-do-panel__item">
                <span class="what-we-do-panel__num">04</span>
                <div>
                  <h4 class="what-we-do-panel__title">커뮤니티 & 오픈소스</h4>
                  <p class="what-we-do-panel__desc">IsaacSimKR 1,000명+ Physical AI 개발자 생태계. 오픈소스 기여 및 기술 문서화.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="company-tabs__panel" data-panel="who">
            <div class="who-we-are who-we-are--panel">
              <div class="who-we-are__member who-we-are__member--ai">
                <h3 class="who-we-are__role">AI / 로보틱스 총괄</h3>
                <p class="who-we-are__expertise">로봇 학습 알고리즘 및<br />강화학습 시스템 설계 경험</p>
                <p class="who-we-are__expertise">Physical AI 연구 및<br />모방학습 기반 시스템 개발</p>
              </div>
              <div class="who-we-are__member who-we-are__member--hardware">
                <h3 class="who-we-are__role">하드웨어 / 시스템 총괄</h3>
                <p class="who-we-are__expertise">로봇 메카니즘 및 구동계 설계,<br />센서 통합 시스템 설계</p>
                <p class="who-we-are__expertise">협동로봇 및 산업용 로봇<br />자동화 시스템 개발 경력</p>
              </div>
              <div class="who-we-are__member who-we-are__member--software">
                <h3 class="who-we-are__role">소프트웨어 / 플랫폼 총괄</h3>
                <p class="who-we-are__expertise">로봇 통합 제어 시스템 및<br />비전 인식 솔루션 개발</p>
                <p class="who-we-are__expertise">제조 현장 최적화 및<br />양산 프로세스 구축 경험</p>
              </div>
            </div>
          </div>

        </div>

        <!-- 좌: 탭 네비게이션 -->
        <div class="company-tabs__nav">
          <span class="company-tabs__label">Our Story</span>
          <h2 class="company-tabs__heading">로봇이 더<br />쉬워지는 곳,<br /><span>로보시지.</span></h2>

          <div class="company-tabs__list">

            <div class="company-tabs__item is-active" data-tab="about">
              <div class="company-tabs__item-header">
                <span class="company-tabs__icon">
                  <i class="fa-solid fa-check company-tabs__icon-check"></i>
                  <i class="fa-solid fa-plus company-tabs__icon-plus"></i>
                </span>
                <span class="company-tabs__title">About Us</span>
              </div>
              <div class="company-tabs__body">
                <p>국내 Physical AI 진입장벽을 낮추는 교육·개발 플랫폼 기업.</p>
              </div>
            </div>

            <div class="company-tabs__item" data-tab="what">
              <div class="company-tabs__item-header">
                <span class="company-tabs__icon">
                  <i class="fa-solid fa-check company-tabs__icon-check"></i>
                  <i class="fa-solid fa-plus company-tabs__icon-plus"></i>
                </span>
                <span class="company-tabs__title">What We Do</span>
              </div>
              <div class="company-tabs__body">
                <p>로봇·AI·가이드·커뮤니티 — 네 가지 축으로 Physical AI 생태계를 만들어 갑니다.</p>
              </div>
            </div>

            <div class="company-tabs__item" data-tab="who">
              <div class="company-tabs__item-header">
                <span class="company-tabs__icon">
                  <i class="fa-solid fa-check company-tabs__icon-check"></i>
                  <i class="fa-solid fa-plus company-tabs__icon-plus"></i>
                </span>
                <span class="company-tabs__title">Who We Are</span>
              </div>
              <div class="company-tabs__body">
                <p>AI + 하드웨어 + 소프트웨어 통합 역량의 세 명이 함께합니다.</p>
              </div>
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="robot-showcase">
    <div class="robot-showcase__container">
      <div class="robot-tabs">

        <!-- 좌: 로봇 이미지 패널 -->
        <div class="robot-tabs__panels">

          <div class="robot-tabs__panel is-active" data-panel="soarm">
            <div class="robot-tabs__img-wrap">
              <img class="robot-tabs__img" src="/img/lerobot-so-arm.png" alt="SO-ARM100" />
            </div>
          </div>

          <div class="robot-tabs__panel" data-panel="lekiwi">
            <div class="robot-tabs__img-wrap">
              <img class="robot-tabs__img" src="/img/lekiwi.png" alt="LeKiwi" />
            </div>
          </div>

          <div class="robot-tabs__panel" data-panel="xlerobot">
            <div class="robot-tabs__img-wrap">
              <img class="robot-tabs__img" src="/img/xlerobot.png" alt="XLeRobot" />
            </div>
          </div>

        </div>

        <!-- 우: 탭 네비게이션 -->
        <div class="robot-tabs__nav">
          <span class="robot-showcase__label">Educational Physical AI</span>
          <h2 class="robot-showcase__heading">로봇 학습의 시작은<br />직접 만지는 것입니다.</h2>

          <div class="robot-tabs__list">

            <div class="robot-tabs__item is-active" data-tab="soarm">
              <div class="robot-tabs__item-header">
                <span class="robot-tabs__icon">
                  <i class="fa-solid fa-check robot-tabs__icon-check"></i>
                  <i class="fa-solid fa-plus robot-tabs__icon-plus"></i>
                </span>
                <span class="robot-tabs__title">SO-ARM</span>
              </div>
              <div class="robot-tabs__body">
                <p>RobotStudio와 Hugging Face가 협력하여 개발한 오픈소스 로봇 팔.</p>
              </div>
            </div>

            <div class="robot-tabs__item" data-tab="xlerobot">
              <div class="robot-tabs__item-header">
                <span class="robot-tabs__icon">
                  <i class="fa-solid fa-check robot-tabs__icon-check"></i>
                  <i class="fa-solid fa-plus robot-tabs__icon-plus"></i>
                </span>
                <span class="robot-tabs__title">XLeRobot</span>
              </div>
              <div class="robot-tabs__body">
                <p>준비중.</p>
              </div>
            </div>

            <div class="robot-tabs__item" data-tab="lekiwi">
              <div class="robot-tabs__item-header">
                <span class="robot-tabs__icon">
                  <i class="fa-solid fa-check robot-tabs__icon-check"></i>
                  <i class="fa-solid fa-plus robot-tabs__icon-plus"></i>
                </span>
                <span class="robot-tabs__title">LeKiwi</span>
              </div>
              <div class="robot-tabs__body">
                <p>준비중.</p>
              </div>
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>


  <section class="content-section">
    <div class="content-section__container">
      <div class="content-section__decorators">
        <span class="content-section__decorator"></span>
        <span class="content-section__decorator"></span>
        <span class="content-section__decorator"></span>
      </div>
      <h2 class="content-section__heading">Join Our Community</h2>
      <div class="community">
        <a target="_blank" rel="noopener" href="https://github.com/roboseasy" class="community__link" aria-label="GitHub">
          <i class="community__icon fa-brands fa-github"></i>
        </a>
        <a target="_blank" rel="noopener" href="https://www.instagram.com/robo_seasy/" class="community__link" aria-label="Instagram">
          <i class="community__icon fa-brands fa-instagram"></i>
        </a>
        <a target="_blank" rel="noopener" href="https://www.youtube.com/@RoboSEasy" class="community__link" aria-label="YouTube">
          <i class="community__icon fa-brands fa-youtube"></i>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Robot tabs
  document.querySelectorAll('.robot-tabs__item').forEach((item) => {
    item.addEventListener('click', () => {
      const tab = item.dataset.tab;
      document.querySelectorAll('.robot-tabs__item').forEach((i) => i.classList.remove('is-active'));
      document.querySelectorAll('.robot-tabs__panel').forEach((p) => p.classList.remove('is-active'));
      item.classList.add('is-active');
      document.querySelector(`.robot-tabs__panel[data-panel="${tab}"]`)?.classList.add('is-active');
    });
  });

  // Company tabs
  document.querySelectorAll('.company-tabs__item').forEach((item) => {
    item.addEventListener('click', () => {
      const tab = item.dataset.tab;
      document.querySelectorAll('.company-tabs__item').forEach((i) => i.classList.remove('is-active'));
      document.querySelectorAll('.company-tabs__panel').forEach((p) => p.classList.remove('is-active'));
      item.classList.add('is-active');
      document.querySelector(`.company-tabs__panel[data-panel="${tab}"]`)?.classList.add('is-active');
    });
  });

  // 스크롤 시 섹션 노출 애니메이션
  const sections = document.querySelectorAll('.content-section, .robot-showcase');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    },
    { root: null, rootMargin: '0px', threshold: 0.1 }
  );
  sections.forEach((section) => observer.observe(section));

</script>

