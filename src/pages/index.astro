---
import BaseLayout from '../layouts/BaseLayout.astro';
import MainBanner from '../components/MainBanner.astro';
import '../styles/pages/home.css';

const title = 'RoboSEasy | 로보시지 - Robot is Easy, 이게 로보시지';
const description = '로봇이 더 쉽고, 더 가까워지도록. 우리는 제품·교육·기술을 통해 전국민의 Physical AI 접근성 향상에 기여합니다';

const newsItems = [
  { title: '아무 제목', date: '2025.01.01' },
  { title: '아무 제목', date: '2025.01.01' },
  { title: '아무 제목', date: '2025.01.01' },
  { title: '아무 제목', date: '2025.01.01' },
];
---
<BaseLayout title={title} description={description} path="/">
  <div class="hero-viewport">
    <MainBanner />

    <!-- 고객사 티커 -->
    <section class="client-ticker-section">
      <div class="client-ticker">
        <div class="client-ticker__track">
          <div class="client-ticker__group">
            <img src="/img/hyundai.png"   alt="현대자동차"   class="client-ticker__logo" />
            <img src="/img/hansung.png"   alt="한성대학교"   class="client-ticker__logo" />
            <img src="/img/opengraph.png" alt="OpenGraph"    class="client-ticker__logo" />
            <img src="/img/hyundai.png"   alt="현대자동차"   class="client-ticker__logo" />
            <img src="/img/hansung.png"   alt="한성대학교"   class="client-ticker__logo" />
            <img src="/img/opengraph.png" alt="OpenGraph"    class="client-ticker__logo" />
          </div>
          <div class="client-ticker__group" aria-hidden="true">
            <img src="/img/hyundai.png"   alt="" class="client-ticker__logo" />
            <img src="/img/hansung.png"   alt="" class="client-ticker__logo" />
            <img src="/img/opengraph.png" alt="" class="client-ticker__logo" />
            <img src="/img/hyundai.png"   alt="" class="client-ticker__logo" />
            <img src="/img/hansung.png"   alt="" class="client-ticker__logo" />
            <img src="/img/opengraph.png" alt="" class="client-ticker__logo" />
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- Services 섹션 -->
  <section class="services-section">
    <div class="services-section__container">
      <div class="services-grid">

        <div class="service-card">
          <div class="service-card__content">
            <h3 class="service-card__title">Hardware</h3>
            <p class="service-card__desc">TheRobotStudio 공식 파트너. SO-ARM100 대한민국 공식 판매처. 초저가 로봇 플랫폼으로 누구나 Physical AI를 시작할 수 있습니다. <a href="/products" class="service-card__link">자세히 보기.</a></p>
          </div>
          <div class="service-card__media">
            <span class="service-card__placeholder-icon">?</span>
          </div>
        </div>

        <div class="service-card">
          <div class="service-card__content">
            <h3 class="service-card__title">Software</h3>
            <p class="service-card__desc">RoboSEasy-Studio 배포. CLI 없이 UI 데스크탑 앱만으로 로봇 데이터 수집부터 학습까지 전 과정을 진행합니다. <a href="/programs" class="service-card__link">자세히 보기.</a></p>
          </div>
          <div class="service-card__media">
            <span class="service-card__placeholder-icon">?</span>
          </div>
        </div>

        <div class="service-card">
          <div class="service-card__content">
            <h3 class="service-card__title">Education</h3>
            <p class="service-card__desc">글로벌 최신 피지컬 AI 기술을 한국어로 정리한 Documents. 누구나 따라할 수 있는 단계별 실습 가이드와 해커톤 운영. <a href="/documents" class="service-card__link">자세히 보기.</a></p>
          </div>
          <div class="service-card__media">
            <span class="service-card__placeholder-icon">?</span>
          </div>
        </div>

        <div class="service-card">
          <div class="service-card__content">
            <h3 class="service-card__title">Community</h3>
            <p class="service-card__desc">피지컬 AI 커뮤니티 1,000명+. 오픈소스 협업과 최신 글로벌 기술을 한국어로 공유하며 함께 성장합니다. <a href="/contact" class="service-card__link">참여하기.</a></p>
          </div>
          <div class="service-card__media">
            <span class="service-card__placeholder-icon">?</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- About Us 섹션 -->
  <section class="content-section">
    <div class="content-section__container">
      <div class="about-tabs">

        <!-- 우: 탭별 패널 -->
        <div class="about-tabs__panels">

          <div class="about-tabs__panel is-active" data-panel="hardware">
            <div class="about-tabs__media">
              <div class="placeholder-img">
                <span class="placeholder-img__icon">?</span>
              </div>
            </div>
          </div>

          <div class="about-tabs__panel" data-panel="software">
            <div class="about-tabs__media">
              <div class="placeholder-img">
                <span class="placeholder-img__icon">?</span>
              </div>
            </div>
          </div>

          <div class="about-tabs__panel" data-panel="education">
            <div class="about-tabs__media">
              <div class="placeholder-img">
                <span class="placeholder-img__icon">?</span>
              </div>
            </div>
          </div>

        </div>

        <!-- 좌: 탭 네비게이션 -->
        <div class="about-tabs__nav">
          <h2 class="about-tabs__label">About Us</h2>

          <div class="about-tabs__list">

            <div class="about-tabs__item is-active" data-tab="hardware">
              <div class="about-tabs__item-header">
                <span class="about-tabs__icon">
                  <iconify-icon icon="solar:check-circle-bold" class="about-tabs__icon-check"></iconify-icon>
                  <iconify-icon icon="solar:add-circle-bold" class="about-tabs__icon-plus"></iconify-icon>
                </span>
                <span class="about-tabs__title">Hardware</span>
              </div>
              <div class="about-tabs__body">
                <p>TheRobotStudio 공식 파트너.<br>SO-ARM 대한민국 공식 판매처.</p>
              </div>
            </div>

            <div class="about-tabs__item" data-tab="software">
              <div class="about-tabs__item-header">
                <span class="about-tabs__icon">
                  <iconify-icon icon="solar:check-circle-bold" class="about-tabs__icon-check"></iconify-icon>
                  <iconify-icon icon="solar:add-circle-bold" class="about-tabs__icon-plus"></iconify-icon>
                </span>
                <span class="about-tabs__title">Software</span>
              </div>
              <div class="about-tabs__body">
                <p>RoboSEasy-Studio 배포.<br>CLI가 아닌 UI 데스크탑 앱.</p>
              </div>
            </div>

            <div class="about-tabs__item" data-tab="education">
              <div class="about-tabs__item-header">
                <span class="about-tabs__icon">
                  <iconify-icon icon="solar:check-circle-bold" class="about-tabs__icon-check"></iconify-icon>
                  <iconify-icon icon="solar:add-circle-bold" class="about-tabs__icon-plus"></iconify-icon>
                </span>
                <span class="about-tabs__title">Education</span>
              </div>
              <div class="about-tabs__body">
                <p>피지컬 AI 커뮤니티 운영 (1,000명+).<br>해커톤 개최 · 한국어 Documents.</p>
              </div>
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Our Vision 섹션 -->
  <section class="vision-section">
    <div class="vision-section__container">
      <h2 class="content-section__heading">Our Vision</h2>
      <div class="vision-section__tags">
        <span class="vision-section__tag">#피지컬 AI</span>
        <span class="vision-section__tag">#로봇 제조</span>
        <span class="vision-section__tag">#로봇 교육</span>
        <span class="vision-section__tag">#로봇 컨설팅</span>
      </div>
      <div class="vision-cards">
        <div class="vision-card">
          <span class="vision-card__num">Mission 01</span>
          <h3 class="vision-card__title">모두를 위한 로봇</h3>
          <p class="vision-card__desc">수천만 원짜리 산업용이 아닌, 학생 메이커도 손에 쥘 수 있는 초저가 플랫폼.</p>
        </div>
        <div class="vision-card">
          <span class="vision-card__num">Mission 02</span>
          <h3 class="vision-card__title">모두를 위한 AI</h3>
          <p class="vision-card__desc">글로벌 최신 기술을 한국어로 정리하고 누구나 쉽게 커스텀할 수 있는 플랫폼.</p>
        </div>
        <div class="vision-card">
          <span class="vision-card__num">Mission 03</span>
          <h3 class="vision-card__title">모두를 위한 가이드</h3>
          <p class="vision-card__desc">어려운 터미널 명령어가 아닌 쉬운 UI 앱과 가이드북으로, 누구나 쉽게 따라하면서 습득하는 Physical AI 전과정.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 뉴스 섹션 (Contact 디자인 패턴) -->
  <section class="content-section">
    <div class="content-section__container">
      <h2 class="content-section__heading">News</h2>
      <div class="news-feature">

        <button class="news-feature__side-btn news-feature__side-btn--prev" aria-label="이전">
          <iconify-icon icon="solar:alt-arrow-left-bold"></iconify-icon>
        </button>

        <div class="news-feature__content">
          {newsItems.map((item, i) => (
            <div class={`news-feature__item${i === 0 ? ' is-active' : ''}`}>
              <div class="news-feature__image">
                <div class="placeholder-img placeholder-img--news">
                  <span class="placeholder-img__icon">?</span>
                </div>
              </div>
              <div class="news-feature__body">
                <h3 class="news-feature__title">{item.title}</h3>
                <div class="news-feature__meta">
                  <time class="news-feature__date">{item.date}</time>
                  <button class="news-feature__view-btn" type="button">뉴스 보기</button>
                </div>
              </div>
            </div>
          ))}
        </div>

        <button class="news-feature__side-btn news-feature__side-btn--next" aria-label="다음">
          <iconify-icon icon="solar:alt-arrow-right-bold"></iconify-icon>
        </button>

      </div>
      <div class="news-feature__counter">
        <span class="news-feature__counter-current">1</span>
        <span class="news-feature__counter-sep"> / </span>
        <span class="news-feature__counter-total">{newsItems.length}</span>
      </div>
    </div>
  </section>


</BaseLayout>

<script>
  // About 탭
  document.querySelectorAll('.about-tabs__item').forEach((item) => {
    item.addEventListener('click', () => {
      const tab = (item as HTMLElement).dataset.tab;
      document.querySelectorAll('.about-tabs__item').forEach((i) => i.classList.remove('is-active'));
      document.querySelectorAll('.about-tabs__panel').forEach((p) => p.classList.remove('is-active'));
      item.classList.add('is-active');
      document.querySelector(`.about-tabs__panel[data-panel="${tab}"]`)?.classList.add('is-active');
    });
  });

  // 뉴스 피처 슬라이더
  const items = document.querySelectorAll<HTMLElement>('.news-feature__item');
  const counterCurrent = document.querySelector<HTMLElement>('.news-feature__counter-current');
  let current = 0;

  function goTo(idx: number) {
    items[current].classList.remove('is-active');
    current = (idx + items.length) % items.length;
    items[current].classList.add('is-active');
    if (counterCurrent) counterCurrent.textContent = String(current + 1);
  }

  document.querySelector('.news-feature__side-btn--prev')?.addEventListener('click', () => goTo(current - 1));
  document.querySelector('.news-feature__side-btn--next')?.addEventListener('click', () => goTo(current + 1));

  // 스크롤 시 섹션 노출 애니메이션
  const sections = document.querySelectorAll('.content-section, .vision-section');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    },
    { root: null, rootMargin: '0px', threshold: 0.1 }
  );
  sections.forEach((section) => observer.observe(section));
</script>
