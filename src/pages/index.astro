---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import MainBanner from '../components/MainBanner.astro';
import '../styles/pages/home.css';
// 랜딩 News 섹션 카드는 Sveltia CMS가 관리하는 landing-news.json에 저장됨.
import { items as newsItems } from '../data/landing-news.json';

const title = 'RoboSEasy | 로보시지';
const description = '로봇이 더 쉽고, 더 가까워지도록. 우리는 제품·교육·기술을 통해 전국민의 Physical AI 접근성 향상에 기여합니다';

// About 섹션 — 핵심 기술 6분야 (좌 3 / 우 3)
const aboutServices = [
  {
    icon: 'solar:gamepad-bold',
    title: '리드 디바이스 기반 실시간 제어',
    points: [
      '사람의 손동작을 로봇 관절로 변환하는 입력–행동 매핑 기술',
      '역기구학(IK) 기반 실시간 제어 알고리즘 개발',
      '글로브 & 스틱 형태의 직관적 인터페이스 설계',
    ],
  },
  {
    icon: 'mdi:robot-industrial',
    title: '양팔 로봇 매니퓰레이션',
    points: [
      '모빌리티 플랫폼과 양팔 매니퓰레이터의 통합 제어',
      'ROS2 기반 모듈화 제어 소프트웨어 아키텍처',
      'RTOS 환경에서의 고정밀 실시간 제어 구현',
    ],
  },
  {
    icon: 'solar:routing-2-bold',
    title: 'SLAM 기반 자율주행',
    points: [
      'LiDAR · 카메라 융합 SLAM으로 정밀 지도 생성 및 위치 추정',
      '동적 장애물 회피 및 실시간 경로 재계획',
      '실내외 복합 환경에서의 안정적인 내비게이션',
    ],
  },
  {
    icon: 'solar:server-square-bold',
    title: '차량군 관제 시스템',
    points: [
      '다수 로봇의 실시간 위치·상태 통합 모니터링',
      '작업 스케줄링 및 충돌 없는 다중 로봇 경로 조율',
    ],
  },
  {
    icon: 'solar:eye-scan-bold',
    title: '3D 비전 및 객체 인식',
    points: [
      '깊이 카메라 기반 3D 포인트 클라우드 처리',
      '물체 위치·자세 추정으로 정밀 파지(Grasping) 지원',
    ],
  },
  {
    icon: 'solar:compass-bold',
    title: '3D 오도메트리 & 포즈 추정',
    points: [
      'IMU · 카메라 · LiDAR 융합 기반 6-DoF 포즈 추정',
      '누적 오차 보정을 통한 장거리 정밀 이동 경로 추적',
      '피지컬 AI 로봇의 공간 인식 핵심 모듈',
    ],
  },
];
const aboutLeft = aboutServices.slice(0, 3);
const aboutRight = aboutServices.slice(3);

// 스탯 카드 (중앙 정렬, 정적 값) — sub는 날짜/부가설명을 아랫줄로
const aboutStats = [
  { icon: 'solar:flag-2-bold', value: '2025.06', label: '김현우·왕한세 공동창업', highlight: true },
  { icon: 'solar:graph-up-bold', value: '₩125M', label: '2026년 누적 매출', sub: '2026.01~05', highlight: true },
  { icon: 'solar:cart-check-bold', value: '200+', label: '2026년 누적 판매 대수', sub: '2026.01~05', highlight: false },
  { icon: 'solar:translation-bold', value: '100%', label: '한국어 기술 지원', sub: '', highlight: true },
];
---
<BaseLayout title={title} description={description} path="/" lockTheme>
  <div class="hero-viewport">
    <!-- 대한민국 야경 지도 배경 (우측 상단 고정, 대중화 텍스트까지 닿게) -->
    <img src="/img/index_img/hero-korea-map.webp" alt="" aria-hidden="true" class="hero-map" />
    <!-- 히어로 아크 글로우 (배너 뒤에 렌더링) -->
    <div class="hero-arc" aria-hidden="true">
      <svg class="hero-arc__svg" viewBox="0 0 1440 260" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <!-- 좌(현대차) → 중앙(로보시지) → 우(한성대) 색상 그라디언트 -->
          <linearGradient id="hero-arc-grad" x1="0" y1="0" x2="1440" y2="0" gradientUnits="userSpaceOnUse">
            <stop offset="0%"   style="stop-color: var(--brand-hyundai)"/>
            <stop offset="6%"   style="stop-color: var(--brand-hyundai)"/>
            <stop offset="28%"  style="stop-color: var(--brand-roboseasy)"/>
            <stop offset="50%"  style="stop-color: var(--brand-roboseasy)"/>
            <stop offset="72%"  style="stop-color: var(--brand-roboseasy)"/>
            <stop offset="94%"  style="stop-color: var(--brand-hansung)"/>
            <stop offset="100%" style="stop-color: var(--brand-hansung)"/>
          </linearGradient>

          <!-- 와이드 아우라 — 중앙이 가장 높은 글로우 높이 -->
          <filter id="arc-glow-wide" x="-5%" y="-300%" width="110%" height="700%">
            <feGaussianBlur stdDeviation="20 45"/>
          </filter>

          <!-- 미디엄 글로우 -->
          <filter id="arc-glow-med" x="-5%" y="-120%" width="110%" height="340%">
            <feGaussianBlur stdDeviation="7 18"/>
          </filter>

          <!-- 베이스 글로우 — 끝부분 최소 글로우 보장 -->
          <filter id="arc-glow-base" x="-5%" y="-40%" width="110%" height="180%">
            <feGaussianBlur stdDeviation="5 6"/>
          </filter>

          <!-- 샤프 코어 라인 -->
          <filter id="arc-glow-sharp" x="-5%" y="-40%" width="110%" height="180%">
            <feGaussianBlur stdDeviation="1.5 4" result="blur"/>
            <feMerge>
              <feMergeNode in="blur"/>
              <feMergeNode in="SourceGraphic"/>
            </feMerge>
          </filter>
        </defs>

        <!-- 다크 돔 (페이지 배경과 동일) -->
        <ellipse cx="720" cy="760" rx="1800" ry="600" fill="#171717"/>

        <!-- 와이드 아우라 (중앙 글로우 키 가장 높음) -->
        <ellipse cx="720" cy="760" rx="1800" ry="600"
                 fill="none" stroke="url(#hero-arc-grad)" stroke-width="4"
                 filter="url(#arc-glow-wide)" opacity="0.4"/>

        <!-- 미디엄 글로우 -->
        <ellipse cx="720" cy="760" rx="1800" ry="600"
                 fill="none" stroke="url(#hero-arc-grad)" stroke-width="3"
                 filter="url(#arc-glow-med)" opacity="0.7"/>

        <!-- 베이스 글로우 (끝부분 최소 보장) -->
        <ellipse cx="720" cy="760" rx="1800" ry="600"
                 fill="none" stroke="url(#hero-arc-grad)" stroke-width="5"
                 filter="url(#arc-glow-base)" opacity="0.35"/>

        <!-- 샤프 코어 -->
        <ellipse cx="720" cy="760" rx="1800" ry="600"
                 fill="none" stroke="url(#hero-arc-grad)" stroke-width="1.5"
                 filter="url(#arc-glow-sharp)"/>
      </svg>
    </div>

    <MainBanner />
  </div>

  <div class="gradient-wrap">
  <!-- Services 섹션 -->
  <section class="services-section">
    <div class="services-section__container">
      <div class="services-grid">

        <div class="service-card" data-stagger-delay="0">
          <div class="service-card__content">
            <h3 class="service-card__title">Hardware</h3>
            <p class="service-card__desc">TheRobotStudio 공식 파트너 및 SO-ARM100 대한민국 공식 판매처로 국내 초저가 로봇를 선보이고 있습니다. <a href="https://smartstore.naver.com/roboseasy" target="_blank" rel="noopener noreferrer" class="service-card__link">자세히 보기.</a></p>
          </div>
          <div class="service-card__media">
            <img src="/img/index_img/service-hardware.webp" alt="로봇 하드웨어" class="service-card__image" loading="lazy" />
          </div>
        </div>

        <div class="service-card" data-stagger-delay="150">
          <div class="service-card__content">
            <h3 class="service-card__title">Software</h3>
            <p class="service-card__desc">어떤 환경에서든 가능한 로봇 데이터 수집부터 학습까지 전 과정을 RoboSEasy-Studio로 진행합니다. <a href="/programs" class="service-card__link">자세히 보기.</a></p>
          </div>
          <div class="service-card__media">
            <img src="/img/index_img/service-software.webp" alt="RoboSEasy-Studio 소프트웨어" class="service-card__image" loading="lazy" />
          </div>
        </div>

        <div class="service-card" data-stagger-delay="0">
          <div class="service-card__content">
            <h3 class="service-card__title">Education</h3>
            <p class="service-card__desc">개인부터 학교, 기업까지 다양한 고객에게 제공하는 교육 시스템과 워크샵 서비스를 제공하고 있습니다. <a href="/contact" class="service-card__link">자세히 보기.</a></p>
          </div>
          <div class="service-card__media">
            <img src="/img/index_img/service-education.webp" alt="Physical AI Hackathon" class="service-card__image" loading="lazy" />
          </div>
        </div>

        <div class="service-card" data-stagger-delay="150">
          <div class="service-card__content">
            <h3 class="service-card__title">Community</h3>
            <p class="service-card__desc">Physical AI 1000+명 커뮤니티부터 유튜브, SNS, 블로그까지 다양한 커뮤니티를 준비했습니다. <a href="/news" class="service-card__link">참여하기.</a></p>
          </div>
          <div class="service-card__media">
            <img src="/img/index_img/service-community.webp" alt="Physical AI 커뮤니티" class="service-card__image" loading="lazy" />
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- About Us 섹션 -->
  <section class="about-section" id="about-section">
    <div class="about__container">
      <!-- 헤더 -->
      <div class="about__header" data-reveal>
        <h2 class="about__title">About Us</h2>
        <span class="about__rule" aria-hidden="true"></span>
      </div>

      <div class="about__grid">
        <!-- 중앙 이미지 (전 행 span) -->
        <div class="about__media-col">
          <div class="about__media" data-reveal data-stagger-delay="150">
            <span class="about__media-border" aria-hidden="true"></span>
            <div class="about__media-frame">
              <img src="/img/index_img/about-tech.webp" alt="로보시지 핵심 기술 — 실시간 제어·매니퓰레이션·자율주행·FMS·3D 비전·포즈 추정" class="about__media-img" loading="lazy" />
            </div>
          </div>
        </div>

        <!-- 좌·우 항목을 행별로 교차 배치 → 같은 행을 공유해 제목 줄 정렬 -->
        {[0, 1, 2].map((row) => [
          { s: aboutLeft[row], dir: 'left' },
          { s: aboutRight[row], dir: 'right' },
        ].map(({ s, dir }) => (
          <article class="about-item" data-reveal data-dir={dir} data-stagger-delay={row * 120}>
            <div class="about-item__header">
              <span class="about-item__icon">
                <Icon name={s.icon} />
              </span>
              <h3 class="about-item__title">{s.title}</h3>
            </div>
            <ul class="about-item__body">
              {s.points.map((p) => <li>{p}</li>)}
            </ul>
          </article>
        )))}
      </div>

      <!-- 스탯 -->
      <div class="about__stats">
        {aboutStats.map((stat, i) => (
          <div class="about-stat" data-reveal data-stagger-delay={i * 100}>
            <span class="about-stat__icon"><Icon name={stat.icon} /></span>
            <span class={`about-stat__value${stat.highlight ? ' about-stat__value--accent' : ''}`}>{stat.value}</span>
            <span class="about-stat__label">
              {stat.label}
              {stat.sub && <span class="about-stat__sub">{stat.sub}</span>}
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our Vision 섹션 -->
  <section class="vision-section">
    <div class="vision-section__container">
      <h2 class="content-section__heading">Our Vision</h2>
      <div class="vision-section__tags">
        <span class="vision-section__tag">#기술지체 없는 대한민국</span>
        <span class="vision-section__tag">#Physical AI 주권</span>
        <span class="vision-section__tag">#모두의 로봇</span>
        <span class="vision-section__tag">#국가 발전 기여</span>
      </div>
      <div class="vision-cards">
        <div class="vision-card">
          <span class="vision-card__num">Vision 01</span>
          <h3 class="vision-card__title">Accessibilty</h3>
          <p class="vision-card__desc">초저가 하드웨어와 소프트웨어로 로봇 진입 장벽을 허뭅니다.</p>
        </div>
        <div class="vision-card">
          <span class="vision-card__num">Vision 02</span>
          <h3 class="vision-card__title">Ecosystem</h3>
          <p class="vision-card__desc">제품·교육·커뮤니티를 잇는 선순환으로 Physical AI 생태계를 키웁니다.</p>
        </div>
        <div class="vision-card">
          <span class="vision-card__num">Vision 03</span>
          <h3 class="vision-card__title">Leadership</h3>
          <p class="vision-card__desc">대한민국 Physical AI 기술로 세계 시장을 선도하는 기업으로 키웁니다.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 뉴스 섹션 (Contact 디자인 패턴) -->
  <section class="content-section">
    <div class="content-section__container">
      <h2 class="content-section__heading">News</h2>
      <div class="news-feature">

        <button class="news-feature__side-btn news-feature__side-btn--prev" aria-label="이전">
          <Icon name="solar:alt-arrow-left-bold" />
        </button>

        <div class="news-feature__content">
          {newsItems.map((item, i) => (
            <div class={`news-feature__item${i === 0 ? ' is-active' : ''}`}>
              <div class="news-feature__image">
                {item.image ? (
                  <img src={item.image} alt={item.title} class="news-feature__img" loading="lazy" />
                ) : (
                  <div class="placeholder-img placeholder-img--news">
                    <span class="placeholder-img__icon">?</span>
                  </div>
                )}
              </div>
              <div class="news-feature__body">
                <h3 class="news-feature__title">{item.title}</h3>
                <div class="news-feature__meta">
                  <time class="news-feature__date">{item.date}</time>
                </div>
              </div>
            </div>
          ))}
        </div>

        <button class="news-feature__side-btn news-feature__side-btn--next" aria-label="다음">
          <Icon name="solar:alt-arrow-right-bold" />
        </button>

      </div>
      <div class="news-feature__counter">
        <span class="news-feature__counter-current">1</span>
        <span class="news-feature__counter-sep"> / </span>
        <span class="news-feature__counter-total">{newsItems.length}</span>
      </div>
    </div>
  </section>
  </div>


</BaseLayout>

<script>
  // About 섹션 — 리빌 / 스탯 카운터 / 배경 패럴럭스
  const aboutSection = document.querySelector('.about-section');
  if (aboutSection) {
    const aboutReveal = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        const el = e.target as HTMLElement;
        const delay = parseInt(el.dataset.staggerDelay ?? '0', 10);
        setTimeout(() => el.classList.add('is-visible'), delay);
        aboutReveal.unobserve(el);
      });
    }, { threshold: 0.15 });
    aboutSection.querySelectorAll('[data-reveal]').forEach((el) => aboutReveal.observe(el));
  }

  // 뉴스 피처 슬라이더
  const newsItems = document.querySelectorAll<HTMLElement>('.news-feature__item');
  const counterCurrent = document.querySelector<HTMLElement>('.news-feature__counter-current');
  let current = 0;

  function goTo(idx: number) {
    newsItems[current].classList.remove('is-active');
    current = (idx + newsItems.length) % newsItems.length;
    newsItems[current].classList.add('is-active');
    if (counterCurrent) counterCurrent.textContent = String(current + 1);
  }

  document.querySelector('.news-feature__side-btn--prev')?.addEventListener('click', () => goTo(current - 1));
  document.querySelector('.news-feature__side-btn--next')?.addEventListener('click', () => goTo(current + 1));

  // 스크롤 애니메이션 헬퍼
  const addVisible = (entries: IntersectionObserverEntry[]) =>
    entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('is-visible'); });

  // 서비스 섹션 컨테이너
  const servicesEl = document.querySelector('.services-section');
  if (servicesEl) {
    new IntersectionObserver(addVisible, { rootMargin: '0px', threshold: 0.05 }).observe(servicesEl);
  }

  // 서비스 카드 개별 관찰 (row1: Hardware/Software, row2: Education/Community 별도 트리거)
  const cardObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const delay = parseInt(el.dataset.staggerDelay ?? '0', 10);
      setTimeout(() => el.classList.add('is-visible'), delay);
      cardObserver.unobserve(el);
    });
  }, { rootMargin: '0px', threshold: 0.1 });
  document.querySelectorAll('.service-card').forEach((c) => cardObserver.observe(c));

  // About / News 섹션 — 시작 지점 늦춤
  const lateObserver = new IntersectionObserver(addVisible, { rootMargin: '-120px', threshold: 0.1 });
  document.querySelectorAll('.content-section').forEach((s) => lateObserver.observe(s));

  // Vision 섹션 — 늦은 트리거 + 카드 순차 등장
  const visionEl = document.querySelector('.vision-section');
  if (visionEl) {
    new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target.classList.add('is-visible');
        entry.target.querySelectorAll('.vision-card').forEach((card, i) => {
          setTimeout(() => card.classList.add('is-visible'), i * 200);
        });
      });
    }, { rootMargin: '-120px', threshold: 0.1 }).observe(visionEl);
  }
</script>
