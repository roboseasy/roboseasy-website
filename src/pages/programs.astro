---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProgramCard from '../components/programs/ProgramCard.astro';
import StudioDownloadSection from '../components/programs/StudioDownloadSection.astro';
import InstallGuideSection from '../components/programs/InstallGuideSection.astro';
import '../styles/pages/programs.css';

const title = 'Programs - RoboSEasy | 로보시지';
const description = 'RoboSEasy Studio 데스크탑 앱과 도구 모음을 다운로드하세요';

const programs = (await getCollection('programs')).sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title={title} description={description} path="/programs">
  <StudioDownloadSection />

  <InstallGuideSection />

  <section class="programs">
    <div class="programs__container">
      <div class="programs__decorators">
        <span class="programs__decorator"></span>
        <span class="programs__decorator"></span>
        <span class="programs__decorator"></span>
      </div>
      <h2 class="programs__heading">추가 프로그램</h2>
      <p class="programs__description">로보시지에서 제공하는 도구를 다운로드하세요</p>
    </div>

    <div class="programs-grid">
      {programs.map(({ data }) => <ProgramCard {...data} />)}
    </div>
  </section>
</BaseLayout>

<script is:inline>
  // 카드 다운로드 버튼 — onclick="return handleDownload(...)" 어트리뷰트 호환을 위해 전역 함수로 노출
  function handleDownload(url) {
    window.open(url, '_blank');
    return false;
  }
</script>
