            <!-- 문의 종류 -->
            <div>
              <label class="field-label req" for="f-type">문의 종류</label>
              <select id="f-type" name="type" class="select" required>
                <option value="" disabled selected>문의 종류를 선택해 주세요</option>
                <option value="purchase">로봇 구매 문의</option>
                <option value="as">로봇 AS 문의</option>
                <option value="workshop">워크샵 문의</option>
