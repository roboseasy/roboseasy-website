                <!-- 배송 주소 -->
                <div>
                  <label class="field-label req" for="f-shipto">배송 주소</label>
                  <input id="f-shipto" name="shipto" type="text" class="input" placeholder="우편번호 / 도로명 주소 / 상세 주소" />
                </div>

                <!-- 견적 항목 (카드형) -->
                <div style="margin-top:20px;">
                  <label class="field-label">견적 항목</label>
                  <div id="quoteRows" class="quote-cards"><!-- cards injected by JS --></div>
                  <button type="button" id="addRowBtn" class="add-row-btn">
                    <iconify-icon icon="solar:add-circle-linear" width="16"></iconify-icon>
                    <span>품목 행 추가</span>
                  </button>

                  <div class="quote-totals">
                    <div class="row">
                      <span>공급가액계</span>
                      <span class="num"><span id="qSubtotal">0</span> 원</span>
                    </div>
                    <div class="row">
                      <span>부가세계</span>
                      <span class="num"><span id="qVat">0</span> 원</span>
                    </div>
                    <div class="row final">
                      <span>최종 견적</span>
                      <span class="num"><span id="qFinal">0</span> 원 <span class="text-muted" style="font-size:0.75rem;font-weight:400;">(부가세 포함)</span></span>
                    </div>
                    <p class="quote-note">※ 부가세는 일의 자리에서 반올림 (10원 단위)</p>
                  </div>
                </div>

                <!-- 견적서 미리보기 / 다운로드 -->
                <div style="display:flex; gap:10px; margin-top:16px; flex-wrap:wrap;">
                  <button type="button" id="previewQuoteBtn" class="btn-quote-action btn-preview-quote">
                    <iconify-icon icon="solar:eye-linear" width="16"></iconify-icon>
                    견적서 미리보기
                  </button>
                  <button type="button" id="downloadQuoteBtn" class="btn-quote-action btn-download-quote">
                    <iconify-icon icon="solar:download-minimalistic-linear" width="16"></iconify-icon>
                    견적서 다운로드
                  </button>
