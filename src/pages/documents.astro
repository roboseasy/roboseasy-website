---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/pages/documents.css';

const title = 'Documentation - RoboSEasy | 로보시지';
const description = '제품별 상세 문서를 확인하세요. LeRobot Library, SO-ARM, XLeRobot, LeKiwi 문서 제공';
---
<BaseLayout title={title} description={description} path="/documents">
  <section class="page-intro">
    <div class="page-intro__container">
      <h1 class="page-intro__heading">Documentation</h1>
      <p class="page-intro__description">제품별 상세 문서를 확인하세요</p>
    </div>
  </section>

  <section class="documents">
    <div class="docs-grid">
      <div class="doc-card">
        <a href="/docs/lerobot-library" class="doc-card__image-wrap">
          <img class="doc-card__image" src="/img/lerobot-library.png" alt="LeRobot Library" />
        </a>
        <div class="doc-card__body">
          <h3 class="doc-card__title">LeRobot Library</h3>
          <p class="doc-card__description">
            HuggingFace LeRobot 라이브러리 사용 가이드.<br />
            로봇 학습 알고리즘 및 데이터셋 활용 방법을 제공합니다.
          </p>
          <a href="/docs/lerobot-library" class="doc-card__button"><i class="fas fa-arrow-right"></i> 더 알아보기</a>
        </div>
      </div>

      <div class="doc-card">
        <a href="/docs/lerobot-so-arm" class="doc-card__image-wrap">
          <img class="doc-card__image" src="/img/lerobot-so-arm.png" alt="LeRobot SO-ARM" />
        </a>
        <div class="doc-card__body">
          <h3 class="doc-card__title">LeRobot SO-ARM</h3>
          <p class="doc-card__description">
            오픈소스 로봇 팔 SO-ARM 조립 및 제어 가이드.<br />
            하드웨어 조립부터 소프트웨어 설정까지 상세 안내합니다.
          </p>
          <a href="/docs/lerobot-so-arm" class="doc-card__button"><i class="fas fa-arrow-right"></i> 더 알아보기</a>
        </div>
      </div>

      <div class="doc-card">
        <a href="/docs/xlerobot" class="doc-card__image-wrap">
          <img class="doc-card__image" src="/img/xlerobot.png" alt="XLeRobot" />
        </a>
        <div class="doc-card__body">
          <h3 class="doc-card__title">XLeRobot</h3>
          <p class="doc-card__description">
            확장형 로봇 플랫폼 XLeRobot 활용 가이드.<br />
            다양한 센서와 액추에이터를 연결하여 커스터마이징 가능합니다.
          </p>
          <a href="/docs/xlerobot" class="doc-card__button"><i class="fas fa-arrow-right"></i> 더 알아보기</a>
        </div>
      </div>

      <div class="doc-card">
        <a href="/docs/lekiwi" class="doc-card__image-wrap">
          <img class="doc-card__image" src="/img/lekiwi.png" alt="LeKiwi" />
        </a>
        <div class="doc-card__body">
          <h3 class="doc-card__title">LeKiwi</h3>
          <p class="doc-card__description">
            모바일 로봇 플랫폼 LeKiwi 개발 가이드.<br />
            자율주행 및 비전 인식 기능 구현 방법을 안내합니다.
          </p>
          <a href="/docs/lekiwi" class="doc-card__button"><i class="fas fa-arrow-right"></i> 더 알아보기</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
