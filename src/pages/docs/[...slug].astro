---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/docs/Sidebar.astro';
import '../../styles/pages/docs.css';

type Category = 'lerobot-library' | 'lerobot-so-arm' | 'lekiwi' | 'xlerobot';

const heroByCategory: Record<Category, { heading: string; description: string }> = {
  'lerobot-library': {
    heading: 'LeRobot Library',
    description: 'HuggingFace LeRobot 라이브러리 완벽 가이드',
  },
  'lerobot-so-arm': {
    heading: 'LeRobot SO-ARM',
    description: 'SO-ARM 101 조립부터 텔레오퍼레이션까지 완벽 가이드',
  },
  lekiwi: {
    heading: 'LeKiwi',
    description: 'LeKiwi 모바일 로봇 플랫폼 개발 가이드',
  },
  xlerobot: {
    heading: 'XLeRobot',
    description: 'XLeRobot 확장형 로봇 플랫폼 활용 가이드',
  },
};

// entry → URL slug (index.md 는 카테고리 루트로 매핑)
function entrySlugToParam(entrySlug: string): string {
  return entrySlug.endsWith('/index') ? entrySlug.replace(/\/index$/, '') : entrySlug;
}

export async function getStaticPaths() {
  const entries = await getCollection('docs');
  return entries.map((entry) => {
    const slug = entry.slug.endsWith('/index') ? entry.slug.replace(/\/index$/, '') : entry.slug;
    return {
      params: { slug },
      props: { entry },
    };
  });
}

interface Props {
  entry: CollectionEntry<'docs'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const category = entry.data.category as Category;
const hero = heroByCategory[category];
const currentPath = `/docs/${entrySlugToParam(entry.slug)}`;

// 같은 카테고리에서 이전/다음 항목 계산
const siblings = (await getCollection('docs', ({ data }) => data.category === category)).sort(
  (a, b) => a.data.order - b.data.order
);
const idx = siblings.findIndex((e) => e.id === entry.id);
const prev = idx > 0 ? siblings[idx - 1] : null;
const next = idx < siblings.length - 1 ? siblings[idx + 1] : null;

function pagerHref(e: CollectionEntry<'docs'>): string {
  return `/docs/${entrySlugToParam(e.slug)}`;
}

const seoTitle = `${entry.data.title} - ${hero.heading} | RoboSEasy`;
const seoDesc = entry.data.description ?? hero.description;
---
<BaseLayout title={seoTitle} description={seoDesc} path={currentPath}>
  <div class="docs-layout">
    <Sidebar category={category} currentPath={currentPath} />

    <article class="docs-content">
      <Content />

      <nav class="docs-pager" aria-label="문서 페이지 네비게이션">
        {prev ? (
          <a class="docs-pager__link docs-pager__link--prev" href={pagerHref(prev)}>
            <span class="docs-pager__hint">← 이전</span>
            <span class="docs-pager__title">{prev.data.title}</span>
          </a>
        ) : <span></span>}
        {next ? (
          <a class="docs-pager__link docs-pager__link--next" href={pagerHref(next)}>
            <span class="docs-pager__hint">다음 →</span>
            <span class="docs-pager__title">{next.data.title}</span>
          </a>
        ) : <span></span>}
      </nav>
    </article>
  </div>

  <button class="docs-sidebar-toggle" aria-label="목차 열기" type="button">☰</button>
</BaseLayout>

<script is:inline>
  // 모바일 사이드바 토글
  const toggle = document.querySelector('.docs-sidebar-toggle');
  const sidebar = document.querySelector('.docs-sidebar');
  if (toggle && sidebar) {
    toggle.addEventListener('click', () => {
      sidebar.classList.toggle('is-open');
    });
    // 사이드바 링크 클릭 시 자동 닫기
    sidebar.querySelectorAll('.docs-sidebar__link').forEach((link) => {
      link.addEventListener('click', () => sidebar.classList.remove('is-open'));
    });
  }
</script>
