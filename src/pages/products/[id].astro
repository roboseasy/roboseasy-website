---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BrandPlaceholder from '../../components/shop/BrandPlaceholder.astro';
import { products, CATEGORY_LABELS, NAVER_STORE_URL } from '../../data/products';
import type { Product } from '../../data/products';
import '../../styles/pages/product-detail.css';

export function getStaticPaths() {
  return products.map((p) => ({ params: { id: p.id }, props: { product: p } }));
}

interface Props { product: Product }
const { product } = Astro.props;
const { name, category, price, summary, image, gallery, detailImages, specImages, naverUrl, comingSoon, productNumber, brand, origin } = product;
const hasProductInfo = Boolean(productNumber || brand || origin);

const buyUrl = naverUrl ?? NAVER_STORE_URL;
// 썸네일이 메인 이미지를 구동 — 대표 이미지를 첫 썸네일로 포함시켜
// 다른 썸네일을 본 뒤 다시 메인(대표)으로 복귀할 수 있게 함
const galleryImages = gallery && gallery.length ? gallery : [];
const thumbSrcs = [image, ...galleryImages].filter(Boolean);
const mainSrc = thumbSrcs[0] ?? null;
// 이미지 미확보 — 데이터가 없으면 플레이스홀더 슬롯으로 채움
const thumbs = thumbSrcs.length ? thumbSrcs : Array.from({ length: 4 }, () => null);
const details = detailImages && detailImages.length ? detailImages : Array.from({ length: 2 }, () => null);
const specs = specImages && specImages.length ? specImages : Array.from({ length: 1 }, () => null);

const title = `${name} - RoboSEasy | 로보시지`;
const description = summary ?? `${name} 제품 정보와 구매 안내.`;
---
<BaseLayout title={title} description={description} path={`/products/${product.id}`} lockTheme="light">
  <article class="pdp">
    <div class="pdp__container">
      <!-- 상단: 좌측 갤러리 / 우측 정보 -->
      <div class="pdp__top">
        <!-- 갤러리 -->
        <div class="pdp__gallery">
          <div class="pdp__main">
            {mainSrc ? (
              <img class="pdp__main-img" src={mainSrc} alt={name} />
            ) : (
              <BrandPlaceholder />
            )}
          </div>
          <div class="pdp__thumbs">
            {thumbs.map((thumb, i) => (
              <div class={`pdp__thumb${i === 0 ? ' is-active' : ''}`}>
                {thumb ? <img src={thumb} alt={`${name} ${i + 1}`} /> : <BrandPlaceholder />}
              </div>
            ))}
          </div>
        </div>

        <!-- 정보 (sticky) -->
        <div class="pdp__info">
          <span class="pdp__category">{CATEGORY_LABELS[category]}</span>
          <h1 class="pdp__name">{name}</h1>
          <p class="pdp__price">{comingSoon ? '가격 미정' : `${price.toLocaleString('ko-KR')}원`}</p>

          <hr class="pdp__divider" />
          <div class="pdp__meta">
            <section class="pdp__meta-group">
              <h2 class="pdp__meta-title">배송정보</h2>
              <dl class="pdp__meta-list">
                <div class="pdp__meta-row"><dt>배송 기간</dt><dd>평균 3일 이내 도착 확률 100%</dd></div>
                <div class="pdp__meta-row"><dt>배송비</dt><dd>무료배송 (100,000원 이상 무료)</dd></div>
                <div class="pdp__meta-row"><dt>배송/출고</dt><dd>GSPostbox택배</dd></div>
              </dl>
            </section>
            {hasProductInfo && (
              <section class="pdp__meta-group">
                <h2 class="pdp__meta-title">상품정보</h2>
                <dl class="pdp__meta-list">
                  {productNumber && <div class="pdp__meta-row"><dt>상품번호</dt><dd>{productNumber}</dd></div>}
                  {brand && <div class="pdp__meta-row"><dt>브랜드</dt><dd>{brand}</dd></div>}
                  {origin && <div class="pdp__meta-row"><dt>원산지</dt><dd>{origin}</dd></div>}
                </dl>
              </section>
            )}
          </div>

          {summary && <p class="pdp__summary">{summary}</p>}
          <div class="pdp__actions">
            {comingSoon ? (
              <span class="pdp__buy pdp__buy--disabled" aria-disabled="true">출시 예정</span>
            ) : (
              <a class="pdp__buy" href={buyUrl} target="_blank" rel="noopener noreferrer">구매하기</a>
            )}
            <a class="pdp__quote" href="/contact">견적보기</a>
          </div>
        </div>
      </div>

      <!-- 하단: 상세 정보 탭 (설명 / 제원) -->
      <section class="pdp__detail">
        <nav class="pdp__tabs" aria-label="상세 정보">
          <button type="button" class="pdp__tab is-active" data-tab="desc">설명</button>
          <button type="button" class="pdp__tab" data-tab="spec">제원</button>
        </nav>

        <div class="pdp__tab-panel is-active" data-panel="desc">
          <div class="pdp__detail-list">
            {details.map((d, i) => (
              <div class="pdp__detail-item">
                {d ? <img src={d} alt={`${name} 상세 ${i + 1}`} loading="lazy" /> : <BrandPlaceholder />}
              </div>
            ))}
          </div>
        </div>

        <div class="pdp__tab-panel" data-panel="spec">
          <div class="pdp__detail-list">
            {specs.map((s, i) => (
              <div class="pdp__detail-item">
                {s ? <img src={s} alt={`${name} 제원 ${i + 1}`} loading="lazy" /> : <BrandPlaceholder />}
              </div>
            ))}
          </div>
        </div>
      </section>
    </div>
  </article>
</BaseLayout>

<script>
  // 상세 정보 탭 — 설명 / 제원 전환
  const tabs = document.querySelectorAll<HTMLButtonElement>('.pdp__tab');
  const panels = document.querySelectorAll<HTMLElement>('.pdp__tab-panel');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => t.classList.toggle('is-active', t === tab));
      panels.forEach((p) => p.classList.toggle('is-active', p.dataset.panel === tab.dataset.tab));
    });
  });

  // 갤러리 — 하위(썸네일) 이미지 클릭 시 메인 이미지로 교체
  const mainImg = document.querySelector<HTMLImageElement>('.pdp__main-img');
  const thumbItems = document.querySelectorAll<HTMLElement>('.pdp__thumb');
  thumbItems.forEach((thumb) => {
    const img = thumb.querySelector('img');
    if (!img) return; // 플레이스홀더(이미지 없음) 슬롯은 건너뜀
    thumb.addEventListener('click', () => {
      if (mainImg) {
        mainImg.src = img.src;
        mainImg.alt = img.alt;
      }
      thumbItems.forEach((t) => t.classList.toggle('is-active', t === thumb));
    });
  });
</script>
