---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/pages/news.css';
// Instagram은 운영자가 CMS(news.json)에 ID를 입력 → 공식 임베드. 상위 3개 노출.
import { instagramPosts } from '../data/news.json';

const title = 'News - RoboSEasy | 로보시지';
const description = '로보시지의 최신 소식을 확인하세요. Instagram, 블로그, YouTube를 한눈에 볼 수 있습니다';

// ── HTML 엔티티 디코드 (피드 제목용) ──
const decode = (s: string) =>
  s.replace(/&amp;/g, '&').replace(/&lt;/g, '<').replace(/&gt;/g, '>')
   .replace(/&quot;/g, '"').replace(/&#0?39;/g, "'").replace(/&#x27;/g, "'");

// ── 블로그(Blogger) 최신 6개 — 빌드 시 공식 JSON 피드에서 수집 ──
interface BlogPost { title: string; url: string; date: string; excerpt: string; thumb: string | null; }
let blogPosts: BlogPost[] = [];
try {
  const res = await fetch('https://roboseasy.blogspot.com/feeds/posts/default?alt=json&max-results=6');
  const data = await res.json();
  blogPosts = (data.feed?.entry ?? []).map((e: any): BlogPost => {
    const html: string = e.content?.$t ?? e.summary?.$t ?? '';
    const text = html.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
    const imgMatch = html.match(/<img[^>]+src="([^"]+)"/);
    const thumb: string | null =
      e['media$thumbnail']?.url?.replace(/\/s72-c\//, '/w640/') ?? imgMatch?.[1] ?? null;
    const link = (e.link ?? []).find((l: any) => l.rel === 'alternate');
    return {
      title: decode(e.title?.$t ?? ''),
      url: link?.href ?? 'https://roboseasy.blogspot.com/',
      date: (e.published?.$t ?? '').slice(0, 10).replace(/-/g, '.'),
      excerpt: text.slice(0, 100),
      thumb,
    };
  });
} catch (err) {
  console.error('[news] Blogger 피드 수집 실패:', err);
}

// ── YouTube 최신 6개 — 빌드 시 채널 RSS에서 수집 (API 키 불필요) ──
const YT_CHANNEL_ID = 'UCPZgh6XSJRDo3HJM-RDdlXQ';
interface YtVideo { id: string; title: string; }
let ytVideos: YtVideo[] = [];
try {
  const res = await fetch(`https://www.youtube.com/feeds/videos.xml?channel_id=${YT_CHANNEL_ID}`);
  const xml = await res.text();
  ytVideos = xml.split('<entry>').slice(1, 7).map((entry): YtVideo => ({
    id: entry.match(/<yt:videoId>([^<]+)<\/yt:videoId>/)?.[1] ?? '',
    title: decode(entry.match(/<title>([^<]*)<\/title>/)?.[1] ?? ''),
  })).filter((v) => v.id);
} catch (err) {
  console.error('[news] YouTube 피드 수집 실패:', err);
}
---
<BaseLayout title={title} description={description} path="/news">
  <section class="page-intro">
    <div class="page-intro__container">
      <h1 class="page-intro__heading">News</h1>
      <p class="page-intro__description">로보시지의 최신 소식을 확인하세요</p>
    </div>
  </section>

  <section class="news">
    <div class="news__tabs-wrap">
      <div class="news__tabs">
        <button class="news__tab news__tab--active" data-tab="instagram">Instagram</button>
        <button class="news__tab" data-tab="blog">블로그</button>
        <button class="news__tab" data-tab="youtube">YouTube</button>
      </div>
    </div>

    <div class="news__content">
      <!-- Instagram: 공식 임베드 1×3 (상위 3개) -->
      <div class="news__panel news__panel--active" data-panel="instagram">
        <div class="instagram-feed">
          {instagramPosts.slice(0, 3).map((id) => (
            <div class="instagram-feed__post">
              <blockquote
                class="instagram-media instagram-feed__embed"
                data-instgrm-captioned
                data-instgrm-permalink={`https://www.instagram.com/p/${id}/?img_index=1/`}
                data-instgrm-version="14"
              ></blockquote>
            </div>
          ))}
        </div>
      </div>

      <!-- 블로그: 최신 글 3개 (Blogger 피드 자동 수집) -->
      <div class="news__panel" data-panel="blog">
        {blogPosts.length > 0 ? (
          <div class="blog-feed">
            {blogPosts.map((post) => (
              <a class="blog-card" href={post.url} target="_blank" rel="noopener noreferrer">
                <div class="blog-card__media">
                  {post.thumb ? (
                    <img src={post.thumb} alt={post.title} class="blog-card__img" loading="lazy" />
                  ) : (
                    <div class="blog-card__placeholder"><span>RoboSEasy</span></div>
                  )}
                </div>
                <div class="blog-card__body">
                  <h3 class="blog-card__title">{post.title}</h3>
                  <p class="blog-card__excerpt">{post.excerpt}…</p>
                  <time class="blog-card__date">{post.date}</time>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <p class="news__empty">블로그 글을 불러오지 못했습니다. <a href="https://roboseasy.blogspot.com/" target="_blank" rel="noopener noreferrer">블로그 바로가기 →</a></p>
        )}
      </div>

      <!-- YouTube: 영상만 2×3 (최신 6개, RSS 자동 수집) -->
      <div class="news__panel" data-panel="youtube">
        {ytVideos.length > 0 ? (
          <div class="instagram-feed">
            {ytVideos.map((video) => (
              <iframe
                class="youtube-video__iframe"
                src={`https://www.youtube.com/embed/${video.id}`}
                title={video.title}
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
              ></iframe>
            ))}
          </div>
        ) : (
          <p class="news__empty">영상을 불러오지 못했습니다. <a href="https://www.youtube.com/@RoboSEasy" target="_blank" rel="noopener noreferrer">YouTube 채널 →</a></p>
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const tabs = document.querySelectorAll('.news__tab');
  const panels = document.querySelectorAll('.news__panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const targetTab = (tab as HTMLElement).dataset.tab;
      tabs.forEach((t) => t.classList.remove('news__tab--active'));
      panels.forEach((p) => p.classList.remove('news__panel--active'));
      tab.classList.add('news__tab--active');
      const targetPanel = document.querySelector(`.news__panel[data-panel="${targetTab}"]`);
      targetPanel?.classList.add('news__panel--active');
    });
  });
</script>

<!-- Instagram embed -->
<script async src="https://www.instagram.com/embed.js" is:inline></script>
