---
import ShopLayout from '../layouts/ShopLayout.astro';
---
<ShopLayout
  title="Products · RoboSEasy Shop"
  description="로보시지 LeRobot 시리즈 — 입문용 SO-ARM부터 듀얼암, 모바일 베이스까지."
  path="/products"
>

<style is:global>
  /* ===== Products Page ===== */
  .products-page {
    background: var(--color-chalk);
    min-height: 60vh;
  }


  /* Main two-column layout */
  .products-main {
    max-width: var(--page-max-width);
    margin: 0 auto;
    padding: 40px clamp(20px, 4vw, 48px) 80px;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: clamp(20px, 3vw, 40px);
    align-items: start;
  }
  @media (max-width: 900px) {
    .products-main { grid-template-columns: 1fr; }
  }

  /* Sidebar */
  .cat-group { padding: 8px 0; }
  .cat-label {
    display: block;
    font-family: var(--font-display);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-steel);
    font-weight: 700;
    padding: 8px 4px;
  }
  .cat-list { display: flex; flex-direction: column; gap: 2px; }
  .cat-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    text-align: left;
    padding: 9px 12px;
    border-radius: 10px;
    border: 1px solid transparent;
    background: none;
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-slate);
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }
  .cat-item:hover { background: var(--color-ash-border); color: var(--color-ink); }
  .cat-item.active {
    background: rgba(94, 81, 248, 0.08);
    border-color: rgba(94, 81, 248, 0.2);
    color: var(--color-ink);
    font-weight: 600;
  }
  .cat-item .count {
    font-size: 12px;
    color: var(--color-steel);
    font-variant-numeric: tabular-nums;
  }
  .cat-item.active .count { color: var(--color-signal-violet); font-weight: 700; }

  /* Filter bar */
  .filter-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 12px 0 16px;
    border-bottom: 1px solid var(--color-ash-border);
  }
  .filter-bar__sort-wrap { display: flex; align-items: center; gap: 10px; }
  .filter-bar__sort-label {
    font-family: var(--font-display);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-steel);
    font-weight: 600;
  }
  .sort-select {
    padding: 7px 30px 7px 12px;
    border: 1px solid var(--color-ash-border);
    border-radius: var(--radius-inputs);
    background-color: var(--color-pure-white);
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-ink);
    appearance: none;
    cursor: pointer;
    background-image:
      linear-gradient(45deg, transparent 50%, var(--color-slate) 50%),
      linear-gradient(135deg, var(--color-slate) 50%, transparent 50%);
    background-position: calc(100% - 14px) 52%, calc(100% - 10px) 52%;
    background-size: 4px 4px, 4px 4px;
    background-repeat: no-repeat;
  }
  .sort-select:focus {
    outline: none;
    border-color: var(--color-signal-violet);
    box-shadow: 0 0 0 3px rgba(94, 81, 248, 0.12);
  }
  .filter-bar__count {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-slate);
    font-variant-numeric: tabular-nums;
  }
  .filter-bar__count strong { color: var(--color-ink); font-weight: 700; }

  /* Product grid */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(16px, 1.6vw, 24px);
    padding: 20px 0 32px;
  }
  @media (max-width: 1100px) {
    .product-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .product-grid { grid-template-columns: 1fr; }
  }

  /* Product card */
  .product-card {
    display: flex;
    flex-direction: column;
    background: var(--color-pure-white);
    border: 1px solid var(--color-ash-border);
    border-radius: var(--radius-cards);
    overflow: hidden;
    cursor: pointer;
    box-shadow: var(--shadow-xl);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.35s ease, border-color 0.3s ease;
  }
  .product-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-xl-2);
    border-color: rgba(94, 81, 248, 0.3);
  }

  /* Thumbnail */
  .product-thumb {
    aspect-ratio: 1;
    background: var(--color-chalk);
    border-bottom: 1px solid var(--color-ash-border);
    position: relative;
    overflow: hidden;
  }
  .product-thumb img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 12%;
    box-sizing: border-box;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .product-card:hover .product-thumb img { transform: scale(1.05); }

  /* Badge */
  .product-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    padding: 4px 10px;
    border-radius: var(--radius-tags);
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(6px);
    border: 1px solid var(--color-ash-border);
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-signal-violet);
  }

  /* Wishlist */
  .product-wishlist {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 36px;
    height: 36px;
    border-radius: 9999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(6px);
    border: 1px solid var(--color-ash-border);
    color: var(--color-slate);
    font-size: 16px;
    cursor: pointer;
    transition: color 0.2s ease, transform 0.3s ease;
  }
  .product-wishlist:hover { color: var(--color-signal-violet); transform: scale(1.06); }

  /* Card meta */
  .product-meta {
    padding: 16px 18px 20px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .product-cat {
    font-family: var(--font-display);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-signal-violet);
  }
  .product-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-body);
    color: var(--color-ink);
    line-height: 1.3;
    letter-spacing: -0.01em;
  }
  .product-price {
    margin-top: 6px;
    font-family: var(--font-display);
    font-size: var(--text-subheading);
    font-weight: 700;
    color: var(--color-ink);
    font-variant-numeric: tabular-nums;
  }
  .product-price small { font-size: 0.7em; font-weight: 500; color: var(--color-steel); margin-left: 4px; }
  .product-price .muted { color: var(--color-steel); }

  /* Empty state */
  .empty-state {
    grid-column: 1 / -1;
    padding: 64px 24px;
    text-align: center;
    color: var(--color-slate);
    border: 1px dashed var(--color-ash-border);
    border-radius: var(--radius-cards);
    background: var(--color-pure-white);
    font-family: var(--font-body);
    font-size: var(--text-body);
  }
</style>

<div class="products-page">

  <!-- INTRO -->
  <section class="page-intro">
    <div class="page-intro__container">
      <h1 class="page-intro__heading">Products</h1>
      <p class="page-intro__description">로보시지가 직접 만드는 LeRobot 시리즈 — 입문용 SO-ARM부터 듀얼암, 모바일 베이스까지.</p>
    </div>
  </section>

  <!-- MAIN -->
  <main class="products-main">

    <!-- SIDEBAR -->
    <aside>
      <div class="cat-group">
        <span class="cat-label">Category</span>
        <div class="cat-list" id="catList">
          <button type="button" class="cat-item active" data-cat="all">
            <span>All</span>
            <span class="count">3</span>
          </button>
          <button type="button" class="cat-item" data-cat="fullpkg">
            <span>풀패키지</span>
            <span class="count">3</span>
          </button>
          <button type="button" class="cat-item" data-cat="parts">
            <span>부품</span>
            <span class="count">0</span>
          </button>
        </div>
      </div>
    </aside>

    <!-- CONTENT -->
    <section>
      <div class="filter-bar">
        <div class="filter-bar__sort-wrap">
          <label for="sort" class="filter-bar__sort-label">Sort by</label>
          <select id="sort" class="sort-select">
            <option value="recommend">추천순</option>
            <option value="newest">최신순</option>
            <option value="price-asc">가격 낮은순</option>
            <option value="price-desc">가격 높은순</option>
          </select>
        </div>
        <div class="filter-bar__count">
          전체 <strong id="countShown">3</strong> / 3 개 상품
        </div>
      </div>
      <div class="product-grid" id="productGrid"></div>
    </section>

  </main>
</div>

<script is:inline>
  const PRODUCTS = [
    { id: 'lerobot-so-arm', cat: 'fullpkg', category: '풀패키지', name: 'LeRobot SO-ARM', price: 550000, priceText: '550,000원', img: '/img/lerobot-so-arm.png', order: 0 },
    { id: 'xlerobot-dual', cat: 'fullpkg', category: '풀패키지', name: 'XLeRobot Dual SO-ARM', price: 253000, priceText: '253,000원', img: '/img/xlerobot.png', order: 1 },
    { id: 'lekiwi', cat: 'fullpkg', category: '풀패키지', name: 'Lekiwi', price: null, priceText: '미정', priceMuted: true, img: '/img/lekiwi.png', order: 2 },
  ];

  const grid = document.getElementById('productGrid');
  const countEl = document.getElementById('countShown');
  const sortEl = document.getElementById('sort');
  let activeCat = 'all';
  let sortKey = 'recommend';

  function priceHTML(p) {
    if (p.priceMuted) return '<span class="muted">' + p.priceText + '</span> <small>출시 예정</small>';
    return p.priceText + ' <small>VAT 포함</small>';
  }

  function cardHTML(p) {
    return '<article class="product-card" data-id="' + p.id + '" data-cat="' + p.cat + '">'
      + '<div class="product-thumb">'
      + '<span class="product-badge">' + p.category + '</span>'
      + '<img src="' + p.img + '" alt="' + p.name + '" loading="lazy" decoding="async" />'
      + '</div>'
      + '<div class="product-meta">'
      + '<span class="product-cat">' + p.category + '</span>'
      + '<h3 class="product-name">' + p.name + '</h3>'
      + '<div class="product-price">' + priceHTML(p) + '</div>'
      + '</div>'
      + '</article>';
  }

  function render() {
    var list = PRODUCTS.slice();
    if (activeCat !== 'all') list = list.filter(function(p) { return p.cat === activeCat; });
    if (sortKey === 'price-asc') list.sort(function(a, b) { return (a.price !== null ? a.price : Infinity) - (b.price !== null ? b.price : Infinity); });
    else if (sortKey === 'price-desc') list.sort(function(a, b) { return (b.price !== null ? b.price : -1) - (a.price !== null ? a.price : -1); });
    else if (sortKey === 'newest') list.sort(function(a, b) { return b.order - a.order; });

    grid.innerHTML = list.length === 0
      ? '<div class="empty-state">선택한 카테고리에 등록된 상품이 없습니다.</div>'
      : list.map(cardHTML).join('');
    countEl.textContent = list.length;

    grid.querySelectorAll('.product-card').forEach(function(card) {
      card.addEventListener('click', function(e) {
        if (e.target.closest('.product-wishlist')) return;
        location.href = '/product/' + card.dataset.id;
      });
    });
  }

  document.querySelectorAll('#catList .cat-item').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('#catList .cat-item').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      activeCat = btn.dataset.cat;
      render();
    });
  });

  sortEl.addEventListener('change', function() { sortKey = sortEl.value; render(); });

  render();
</script>

</ShopLayout>
